---
import { getCollection } from "astro:content";
import { Icon } from "astro-icon/components";
import BangumiSection from "@/components/pages/bangumi/BangumiSection.astro";
import TabNav from "@/components/pages/bangumi/TabNav.astro";
import { siteConfig } from "@/config";
import { bangumiConfig, bangumiPageConfig } from "@/config/bangumiConfig";
import I18nKey from "@/i18n/i18nKey";
import { i18n } from "@/i18n/translation";
import MainGridLayout from "@/layouts/MainGridLayout.astro";
import type { UserSubjectCollection } from "@/types/bangumi";
import { formatDateI18nWithTime } from "@/utils/date-utils";

if (!siteConfig.pages.bangumi) {
	return Astro.redirect("/404/");
}

const buildTime = formatDateI18nWithTime(new Date());

const categoryMap = {
	book: { id: "book", name: i18n(I18nKey.bangumiCategoryBook), subjectType: 1 },
	anime: {
		id: "anime",
		name: i18n(I18nKey.bangumiCategoryAnime),
		subjectType: 2,
	},
	music: {
		id: "music",
		name: i18n(I18nKey.bangumiCategoryMusic),
		subjectType: 3,
	},
	game: { id: "game", name: i18n(I18nKey.bangumiCategoryGame), subjectType: 4 },
	real: { id: "real", name: i18n(I18nKey.bangumiCategoryReal), subjectType: 6 },
};

const allPosts = await getCollection("posts");

const enabledBangumi = bangumiConfig.filter((item) => item.enabled !== false);

const mappedData: UserSubjectCollection[] = enabledBangumi.map((item) => {
	const categoryInfo = categoryMap[item.category];

	let rawLink = (item.link || "").trim().replace(/\\/g, "/");

	if (!rawLink) {
		rawLink = `/bangumi/${item.id}/`;
	}

	let finalLink = rawLink;

	const normalize = (s: string) =>
		s.toLowerCase().replace(/\\/g, "/").replace(/\/$/, "");

	const matchingPost = allPosts.find((p) => {
		const normalizedId = p.id.replace(/\\/g, "/");
		const slug = normalizedId.replace(/\.(md|mdx|markdown)$/i, "");
		const postUrl = `/posts/${slug}/`;

		const nRaw = normalize(rawLink);
		const nSlug = normalize(slug);
		const nUrl = normalize(postUrl);
		const nId = normalize(normalizedId);

		return (
			nRaw === nUrl ||
			nRaw === nSlug ||
			nRaw === nId ||
			nRaw.endsWith(nSlug) ||
			nRaw.endsWith(nId) ||
			p.data.title === item.title
		);
	});

	if (matchingPost) {
		const normalizedId = matchingPost.id.replace(/\\/g, "/");
		const slug = normalizedId.replace(/\.(md|mdx|markdown)$/i, "");
		finalLink = `/posts/${slug}/`;
	}

	if (!finalLink.startsWith("http") && !finalLink.startsWith("/")) {
		finalLink = "/" + finalLink;
	}

	return {
		subject_id: 0,
		subject_type: categoryInfo.subjectType,
		rate: item.score || 0,
		type: item.status as any,
		comment: item.comment || null,
		tags: item.tags || [],
		ep_status: 0,
		vol_status: 0,
		updated_at: item.published ? new Date(item.published).toISOString() : new Date().toISOString(),
		private: false,
		link: finalLink,
		subject: {
			id: 0,
			type: categoryInfo.subjectType,
			name: item.title,
			name_cn: item.name_cn || item.title,
			short_summary: "",
			images: {
				medium: item.image,
				large: item.image,
				common: item.image,
				small: item.image,
				grid: item.image,
			},
			volumes: 0,
			eps: 0,
			collection_total: 0,
			score: item.score || 0,
			rank: 0,
			tags: (item.tags || []).map((t) => ({
				name: t,
				count: 0,
				total_cont: 0,
			})),
		},
	};
});

mappedData.sort((a, b) => {
	const dateA = new Date(a.updated_at).getTime();
	const dateB = new Date(b.updated_at).getTime();
	return dateB - dateA;
});

const bangumiData: Record<string, UserSubjectCollection[]> = {};
const tabs: Array<{ id: string; name: string; count: number }> = [];

const displayCategories = ["anime", "book", "game", "music"];

for (const key of displayCategories) {
	if (categoryMap[key as keyof typeof categoryMap]) {
		const info = categoryMap[key as keyof typeof categoryMap];
		const items = mappedData.filter((d) => d.subject_type === info.subjectType);
		bangumiData[key] = items;
		tabs.push({
			id: key,
			name: info.name,
			count: items.length,
		});
	}
}

const activeTab = tabs[0]?.id || "anime";
---

<MainGridLayout title={i18n(I18nKey.bangumi)} description={i18n(I18nKey.bangumiSubtitle)}>
	<div class="bangumi-page-wrapper flex w-full overflow-hidden relative min-h-32">
		<div class="card-base z-10 px-6 pt-8 pb-8 relative w-full">
			<!-- Page header -->
			<header class="bangumi-header relative w-full mb-8">
				<div class="flex items-center gap-3 mb-4">
					<div class="bangumi-icon flex items-center justify-center w-12 h-12 rounded-2xl bg-[var(--primary)]/10 dark:bg-[var(--primary)]/15 border border-[var(--primary)]/20 shadow-sm">
						<Icon name="material-symbols:collections-bookmark-outline-rounded" class="text-[1.4rem] text-[var(--primary)]"></Icon>
					</div>
					<div>
						<h1 class="text-2xl font-bold text-[var(--deep-text)] dark:text-[var(--title-active)] tracking-tight">
							{i18n(I18nKey.bangumi)}
						</h1>
					</div>
				</div>
				<p class="text-sm text-[var(--content-meta)] leading-relaxed pl-[3.5rem]">
					{i18n(I18nKey.bangumiSubtitle)}
				</p>
				<p class="text-xs text-[var(--content-meta)] opacity-60 mt-1.5 pl-[3.5rem]">
					{i18n(I18nKey.bangumiLastUpdated)} {buildTime}
				</p>
			</header>

			<!-- Tab navigation and content -->
			{tabs.length > 0 ? (
				<>
					<TabNav tabs={tabs} activeTab={activeTab} />

					{tabs.map((tab) => (
						<BangumiSection
							sectionId={tab.id}
							items={bangumiData[tab.id] || []}
							isActive={tab.id === activeTab}
					itemsPerPage={12}
							itemsPerPageMobile={6}
						/>
					))}
				</>
			) : (
				<div class="flex flex-col items-center justify-center py-20 text-center">
					<div class="inline-flex items-center justify-center w-16 h-16 bg-[var(--btn-regular-bg)] rounded-2xl mb-6 border border-[var(--line-divider)]">
						<Icon name="material-symbols:settings" class="text-[2rem] text-[var(--btn-content)]" />
					</div>
					<h2 class="text-xl font-semibold text-[var(--deep-text)] dark:text-[var(--title-active)] mb-3">
						{i18n(I18nKey.bangumiEmpty)}
					</h2>
					<p class="text-[var(--content-meta)] mb-4 max-w-md mx-auto text-sm">
						请在 src/config/bangumiConfig.ts 中添加条目以显示在此页面
					</p>
				</div>
			)}
		</div>

	</div>
</MainGridLayout>

<style>
	.bangumi-page-wrapper {
		border-radius: var(--radius-large);
	}

	/* Responsive grid */
	.bangumi-grid {
		/* Mobile-first: already set via Tailwind classes */
	}

	/* Smooth page-level transitions */
	.bangumi-header {
		animation: fadeSlideIn 0.4s ease-[var(--ease-standard)] both;
	}

	.bangumi-icon {
		transition: transform 0.2s ease-[var(--ease-standard)];
	}

	.bangumi-icon:hover {
		transform: scale(1.05);
	}

	@keyframes fadeSlideIn {
		from {
			opacity: 0;
			transform: translateY(8px);
		}
		to {
			opacity: 1;
			transform: translateY(0);
		}
	}

	/* Section fade in */
	.bangumi-section {
		animation: fadeIn 0.3s ease-[var(--ease-standard)] both;
	}

	@keyframes fadeIn {
		from { opacity: 0; }
		to { opacity: 1; }
	}

	/* Hide scrollbar for tab nav on mobile but keep it functional */
	.scrollbar-hide {
		-ms-overflow-style: none;
		scrollbar-width: none;
	}

	.scrollbar-hide::-webkit-scrollbar {
		display: none;
	}

	/* Responsive padding adjustments */
	@media (max-width: 640px) {
		.card-base {
			padding-left: 1rem;
			padding-right: 1rem;
			padding-top: 1.5rem;
			padding-bottom: 1.5rem;
		}
	}
</style>
