---
import MainGridLayout from "@/layouts/MainGridLayout.astro";
import { getCollection } from "astro:content";
import { Icon } from "astro-icon/components";
import MomentCard from "@/components/moments/MomentCard.astro";
import Comment from "@/components/comment/index.astro";

const moments = await getCollection("moments");
const sortedMoments = moments.sort(
	(a, b) => b.data.published.getTime() - a.data.published.getTime(),
);

const albums = await getCollection("album");
const albumCount = albums.length;
---

<MainGridLayout title="动态" description="记录生活中的点点滴滴">
    <!-- 动态列表 -->
    <div class="moments-feed">
      {sortedMoments.length > 0 ? (
        sortedMoments.map((moment) => (
          <MomentCard moment={moment} />
        ))
      ) : (
        <div class="empty-state">
          <div class="empty-icon">
            <Icon name="material-symbols:sentiment-neutral-outline" />
          </div>
          <h3 class="empty-title">还没有发布任何说说</h3>
          <p class="empty-desc">快去记录你的生活点滴吧</p>
        </div>
      )}
    </div>

    <!-- 评论区 - 使用统一的 Comment 组件 -->
    <Comment customPath="/moments/" />

    <!-- 访客统计 -->
    <div class="visitor-stat">
      <Icon name="material-symbols:visibility-outline" class="stat-icon" />
      <span class="waline-count" data-path="/moments/">-</span>
      <span class="stat-label">次浏览</span>
    </div>
</MainGridLayout>

<script is:inline>
  // 访客统计
  const countElements = document.querySelectorAll('.waline-count[data-path="/moments/"]');
  if (countElements.length > 0) {
    const serverURL = "https://co.tsh520.cn";
    
    fetch(`${serverURL}/api/uv?path=/moments/`)
      .then(res => res.json())
      .then(data => {
        const count = data.data?.unique_visitor || data.uv || 0;
        countElements.forEach(el => {
          el.textContent = String(count);
        });
      })
      .catch(() => {
        countElements.forEach(el => {
          el.textContent = "-";
        });
      });
  }
</script>

<style>
  /* 动态列表 */
  .moments-feed {
    display: flex;
    flex-direction: column;
    padding: 16px 4px 40px;
  }

  /* 空状态 */
  .empty-state {
    text-align: center;
    padding: 60px 20px;
    background: var(--card-bg);
    border: 1px solid var(--border);
    border-radius: 16px;
  }

  .empty-icon {
    width: 64px;
    height: 64px;
    margin: 0 auto 16px;
    display: flex;
    align-items: center;
    justify-content: center;
    background: var(--bg-color);
    border-radius: 50%;
    color: var(--content-meta);
    font-size: 32px;
  }

  .empty-title {
    font-size: 16px;
    font-weight: 600;
    color: var(--text-color);
    margin-bottom: 6px;
  }

  .empty-desc {
    font-size: 14px;
    color: var(--content-meta);
  }

  /* 访客统计 */
  .visitor-stat {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 6px;
    margin: 24px auto 0;
    padding: 12px;
    color: var(--content-meta);
    font-size: 13px;
  }

  .stat-icon {
    font-size: 16px;
  }

  .waline-count {
    font-weight: 600;
    color: var(--text-color);
  }

  /* 响应式 */
  @media (max-width: 768px) {
    .moments-feed {
      padding: 12px 16px 0;
    }

    .visitor-stat {
      margin: 20px 16px 0;
    }
  }
</style>
