---
import MainGridLayout from "@/layouts/MainGridLayout.astro";
import { getCollection } from "astro:content";
import { Icon } from "astro-icon/components";
import MomentCard from "@/components/moments/MomentCard.astro";

const moments = await getCollection("moments");
const sortedMoments = moments.sort(
	(a, b) => b.data.published.getTime() - a.data.published.getTime(),
);

const albums = await getCollection("album");
const albumCount = albums.length;
---

<MainGridLayout title="动态" description="记录生活中的点点滴滴">
  <div class="moments-container">
    <!-- 侧边栏装饰 -->
    <div class="sidebar-glow left"></div>
    <div class="sidebar-glow right"></div>
    
    <!-- 顶部用户卡片 -->
    <div class="profile-card">
      <div class="profile-bg"></div>
      <div class="profile-content">
        <!-- 头像 -->
        <div class="avatar-wrapper">
          <img 
            src="https://re.0824.uk/zl/tx.webp" 
            alt="头像" 
            class="avatar-img"
          />
          <div class="online-badge"></div>
        </div>
        
        <!-- 用户信息 -->
        <div class="profile-info">
          <h1 class="profile-name">我的动态</h1>
          <p class="profile-bio">记录生活中的每一个美好瞬间</p>
        </div>
        
        <!-- 统计数据 -->
        <div class="profile-stats">
          <div class="stat-item">
            <span class="stat-value waline-count" data-path="/moments/">-</span>
            <span class="stat-label">访客</span>
          </div>
          <div class="stat-divider"></div>
          <div class="stat-item">
            <span class="stat-value">{sortedMoments.length}</span>
            <span class="stat-label">说说</span>
          </div>
          <div class="stat-divider"></div>
          <div class="stat-item">
            <span class="stat-value">{albumCount}</span>
            <span class="stat-label">相册</span>
          </div>
        </div>
      </div>
    </div>

    <!-- 导航标签 -->
    <div class="nav-tabs">
      <a href="/moments/" class="nav-tab active">
        <Icon name="material-symbols:chat-bubble-outline" class="tab-icon" />
        <span class="tab-label">说说</span>
        <span class="tab-count">{sortedMoments.length}</span>
      </a>
      <a href="/album/" class="nav-tab">
        <Icon name="material-symbols:photo-library" class="tab-icon" />
        <span class="tab-label">相册</span>
        <span class="tab-count">{albumCount}</span>
      </a>
      <a href="/life/guestbook/" class="nav-tab">
        <Icon name="material-symbols:edit-note" class="tab-icon" />
        <span class="tab-label">留言板</span>
      </a>
    </div>

    <!-- 时间线 -->
    <div class="timeline-container">
      <!-- 时间线装饰线 -->
      <div class="timeline-line"></div>
      
      <!-- 动态列表 -->
      <div class="moments-feed">
        {sortedMoments.length > 0 ? (
          sortedMoments.map((moment, index) => (
            <div class="moment-wrapper" style={`--delay: ${index * 80}ms`}>
              <div class="moment-timeline-node"></div>
              <MomentCard moment={moment} />
            </div>
          ))
        ) : (
          <div class="empty-state">
            <div class="empty-icon">
              <Icon name="material-symbols:sentiment-neutral-outline" class="text-6xl" />
            </div>
            <h3 class="empty-title">还没有发布任何说说哦~</h3>
            <p class="empty-desc">快去记录你的生活点滴吧！</p>
          </div>
        )}
      </div>
    </div>
  </div>
</MainGridLayout>

<script>
  // 页面初始化
  function initPage() {
    // 动态页面访客统计
    const countElements = document.querySelectorAll('.waline-count[data-path="/moments/"]');
    if (countElements.length > 0) {
      const serverURL = "https://co.tsh520.cn";
      
      fetch(`${serverURL}/api/uv?path=/moments/`)
        .then(res => res.json())
        .then(data => {
          const count = data.data?.unique_visitor || data.uv || 0;
          countElements.forEach(el => {
            el.textContent = String(count);
          });
        })
        .catch(() => {
          countElements.forEach(el => {
            el.textContent = "-";
          });
        });
    }

    // 滚动动画 - 使用 MutationObserver 确保动态加载的内容也被观察
    const observerOptions = {
      threshold: 0,
      rootMargin: '0px 0px -50px 0px'
    };

    const observer = new IntersectionObserver((entries) => {
      entries.forEach(entry => {
        if (entry.isIntersecting) {
          entry.target.classList.add('visible');
          observer.unobserve(entry.target); // 触发后取消观察
        }
      });
    }, observerOptions);

    // 立即触发视口内的元素可见
    function triggerVisible() {
      const wrappers = document.querySelectorAll('.moment-wrapper:not(.visible)');
      wrappers.forEach(wrapper => {
        const rect = wrapper.getBoundingClientRect();
        if (rect.top < window.innerHeight) {
          wrapper.classList.add('visible');
        } else {
          observer.observe(wrapper);
        }
      });
    }

    // 页面加载时立即检查
    triggerVisible();

    // 滚动时继续观察
    window.addEventListener('scroll', triggerVisible, { passive: true });
  }

  // 使用 requestAnimationFrame 确保在下次绘制前执行
  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', () => {
      requestAnimationFrame(initPage);
    });
  } else {
    requestAnimationFrame(initPage);
  }
</script>

<style>
  .moments-container {
    position: relative;
    max-width: 680px;
    margin: 0 auto;
    padding: 0 16px;
  }

  /* 侧边装饰光晕 */
  .sidebar-glow {
    position: fixed;
    top: 50%;
    transform: translateY(-50%);
    width: 400px;
    height: 400px;
    border-radius: 50%;
    pointer-events: none;
    z-index: 0;
  }

  .sidebar-glow.left {
    left: -200px;
    background: radial-gradient(circle, var(--primary) 0%, transparent 70%);
    opacity: 0.15;
  }

  .sidebar-glow.right {
    right: -200px;
    background: radial-gradient(circle, var(--primary) 0%, transparent 70%);
    opacity: 0.1;
  }

  /* 用户卡片 - 透明背景 */
  .profile-card {
    position: relative;
    background: transparent;
    border: 1px solid var(--border);
    border-radius: 24px;
    overflow: hidden;
    margin-bottom: 20px;
    z-index: 1;
  }

  .profile-bg {
    display: none;
  }

  .profile-content {
    position: relative;
    padding: 28px;
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
  }

  .avatar-wrapper {
    position: relative;
    margin-bottom: 16px;
  }

  .avatar-img {
    width: 96px;
    height: 96px;
    border-radius: 50%;
    object-fit: cover;
    border: 4px solid var(--card-bg);
    box-shadow: 0 8px 32px rgba(0, 0, 0, 0.15);
    transition: transform 0.3s ease, box-shadow 0.3s ease;
  }

  .avatar-img:hover {
    transform: scale(1.05);
    box-shadow: 0 12px 40px rgba(0, 0, 0, 0.2);
  }

  .online-badge {
    position: absolute;
    bottom: 6px;
    right: 6px;
    width: 20px;
    height: 20px;
    background: #22c55e;
    border: 4px solid var(--card-bg);
    border-radius: 50%;
    animation: pulse 2s infinite;
  }

  @keyframes pulse {
    0%, 100% { box-shadow: 0 0 0 0 rgba(34, 197, 94, 0.4); }
    50% { box-shadow: 0 0 0 8px rgba(34, 197, 94, 0); }
  }

  .profile-info {
    margin-bottom: 20px;
  }

  .profile-name {
    font-size: 24px;
    font-weight: 700;
    color: var(--text-color);
    margin-bottom: 6px;
  }

  .profile-bio {
    font-size: 14px;
    color: var(--content-meta);
  }

  .profile-stats {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 24px;
    padding: 16px 24px;
    background: transparent;
    border-radius: 16px;
    border: none;
  }

  .stat-item {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 4px;
  }

  .stat-value {
    font-size: 20px;
    font-weight: 700;
    color: var(--primary);
  }

  .stat-label {
    font-size: 12px;
    color: var(--content-meta);
  }

  .stat-divider {
    width: 1px;
    height: 32px;
    background: var(--border);
  }

  /* 导航标签 */
  .nav-tabs {
    display: flex;
    gap: 8px;
    margin-bottom: 24px;
    z-index: 1;
    position: relative;
  }

  .nav-tab {
    flex: 1;
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 8px;
    padding: 14px 20px;
    background: var(--card-bg);
    border: 1px solid var(--border);
    border-radius: 16px;
    color: var(--content-meta);
    font-size: 14px;
    font-weight: 500;
    transition: all 0.3s ease;
    text-decoration: none;
  }

  .nav-tab:hover {
    background: var(--primary)/10;
    border-color: var(--primary)/30;
    color: var(--primary);
    transform: translateY(-2px);
  }

  .nav-tab.active {
    background: var(--primary);
    border-color: var(--primary);
    color: white;
    box-shadow: 0 4px 16px var(--primary)/30;
  }

  .nav-tab.active .tab-icon {
    color: white;
  }

  .tab-icon {
    font-size: 20px;
    color: var(--content-meta);
    transition: color 0.3s;
  }

  .nav-tab:hover .tab-icon {
    color: var(--primary);
  }

  .tab-count {
    padding: 2px 8px;
    background: var(--primary)/10;
    border-radius: 10px;
    font-size: 12px;
    font-weight: 600;
    color: var(--primary);
    transition: all 0.3s;
  }

  .nav-tab.active .tab-count {
    background: rgba(255, 255, 255, 0.2);
    color: white;
  }

  /* 时间线 */
  .timeline-container {
    position: relative;
    padding-left: 32px;
  }

  .timeline-line {
    position: absolute;
    left: 7px;
    top: 0;
    bottom: 0;
    width: 2px;
    background: linear-gradient(
      to bottom,
      var(--primary) 0%,
      var(--primary)/20 50%,
      transparent 100%
    );
    border-radius: 1px;
  }

  .moments-feed {
    position: relative;
  }

  .moment-wrapper {
    position: relative;
    margin-bottom: 20px;
  }

  .moment-wrapper .card-inner {
    opacity: 0;
    transform: translateY(15px);
    transition: opacity 0.4s ease, transform 0.4s ease;
  }

  .moment-wrapper.visible .card-inner {
    opacity: 1;
    transform: translateY(0);
  }

  .moment-timeline-node {
    position: absolute;
    left: -32px;
    top: 24px;
    width: 14px;
    height: 14px;
    background: var(--primary);
    border: 3px solid var(--bg-color);
    border-radius: 50%;
    box-shadow: 0 0 0 3px var(--primary)/20;
    z-index: 1;
  }

  /* 空状态 */
  .empty-state {
    text-align: center;
    padding: 60px 20px;
    background: var(--card-bg);
    border: 1px solid var(--border);
    border-radius: 24px;
  }

  .empty-icon {
    width: 80px;
    height: 80px;
    margin: 0 auto 20px;
    display: flex;
    align-items: center;
    justify-content: center;
    background: var(--primary)/10;
    border-radius: 50%;
    color: var(--primary);
  }

  .empty-title {
    font-size: 18px;
    font-weight: 600;
    color: var(--text-color);
    margin-bottom: 8px;
  }

  .empty-desc {
    font-size: 14px;
    color: var(--content-meta);
  }

  /* 响应式 */
  @media (max-width: 640px) {
    .profile-content {
      padding: 20px;
    }

    .avatar-img {
      width: 72px;
      height: 72px;
    }

    .profile-name {
      font-size: 20px;
    }

    .profile-stats {
      padding: 12px 16px;
      gap: 16px;
    }

    .stat-value {
      font-size: 18px;
    }

    .nav-tab {
      padding: 12px 16px;
      font-size: 13px;
    }

    .tab-icon {
      font-size: 18px;
    }

    .timeline-container {
      padding-left: 24px;
    }

    .timeline-line {
      left: 5px;
    }

    .moment-timeline-node {
      left: -24px;
      width: 12px;
      height: 12px;
    }
  }
</style>
