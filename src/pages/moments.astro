---
import MainGridLayout from "@/layouts/MainGridLayout.astro";
import { getCollection } from "astro:content";
import { Icon } from "astro-icon/components";
import { Image } from "astro:assets";
import MomentCard from "@/components/moments/MomentCard.astro";
import MomentsCover from "@/components/moments/MomentsCover.astro";
import Comment from "@/components/comment/index.astro";
import { externalMomentsConfig } from "@/config/externalMomentsConfig";

const moments = await getCollection("moments");
const sortedMoments = moments
  .filter((m) => !m.data.pinned)
  .sort((a, b) => b.data.published.getTime() - a.data.published.getTime());

// 置顶说说
const pinnedMoments = moments
  .filter((m) => m.data.pinned)
  .sort((a, b) => b.data.published.getTime() - a.data.published.getTime());

// 获取 moments 资产目录下的所有图片
const momentAssets = import.meta.glob<{ default: ImageMetadata }>(
  "../content/moments/assets/*.{jpeg,jpg,png,gif,webp,avif}",
  { eager: true },
);

// 解析图片路径
const parseImages = (imagesData: any): (string | ImageMetadata)[] => {
  let rawPaths: string[] = [];
  if (Array.isArray(imagesData)) {
    rawPaths = imagesData.map((img) =>
      typeof img === "string" ? img : img.src || img,
    );
  } else if (typeof imagesData === "string" && imagesData.trim()) {
    rawPaths = imagesData
      .split(/[,;]/)
      .map((img) => img.trim())
      .filter((img) => img);
  }

  return Array.from(new Set(rawPaths))
    .map((img) => {
      if (
        img.startsWith("http://") ||
        img.startsWith("https://") ||
        img.startsWith("/")
      ) {
        return img;
      }
      const cleanPath = img.replace(/^\.\//, "");
      if (cleanPath.startsWith("assets/")) {
        const fileName = cleanPath.replace("assets/", "");
        for (const path in momentAssets) {
          if (path.endsWith(fileName)) {
            return momentAssets[path].default;
          }
        }
      }
      return img;
    })
    .filter((img) => img);
};

// 预处理置顶说说
const pinnedData = pinnedMoments.map((m) => ({
  images: parseImages(m.data.images),
  body: m.body || "",
  date: m.data.published,
}));

const albums = await getCollection("album");
---

<MainGridLayout title="动态" description="记录生活中的点点滴滴">
  <!-- 微信朋友圈风格封面 -->
  <MomentsCover />

  <!-- 置顶说说（始终渲染容器，JS 可动态追加外部置顶） -->
  <a href="/moments/pinned/" class="wx-pinned" id="pinned-block" style={pinnedData.length === 0 ? 'display:none' : ''}>
    <div class="wx-pinned-tag">
      <span>置顶</span>
    </div>
    <div class="wx-pinned-items" id="pinned-items">
      {pinnedData.map((item) => (
        <div class="wx-pinned-preview">
          {item.images.length > 0 ? (
            <div class={`wx-pimgs wx-pimgs-${Math.min(item.images.length, 9)}`}>
              {item.images.slice(0, 9).map((img) => (
                typeof img === "string" ? (
                  <img src={img} alt="" class="wx-pinned-img" loading="lazy" />
                ) : (
                  <Image src={img} alt="" class="wx-pinned-img" loading="lazy" />
                )
              ))}
            </div>
          ) : (
            <p class="wx-ptxt">{item.body.slice(0, 60)}{item.body.length > 60 ? '...' : ''}</p>
          )}
        </div>
      ))}
    </div>
  </a>

  <!-- 说说列表（本地 + 外部合并，按时间排序） -->
  <div class="wx-feed" id="moments-feed">
    {sortedMoments.length > 0 ? (
      sortedMoments.map((moment) => (
        <div class="wx-feed-item" data-published={moment.data.published.toISOString()}>
          <MomentCard moment={moment} />
        </div>
      ))
    ) : (
      <div class="wx-empty" id="moments-empty">
        <div class="wx-empty-icon">
          <Icon name="material-symbols:sentiment-neutral-outline" />
        </div>
        <h3>还没有发布任何说说</h3>
        <p>快去记录你的生活点滴吧</p>
      </div>
    )}
  </div>

  <!-- 评论区 -->
  <div id="moments-comments">
    <Comment customPath="/moments/" />
  </div>

  <!-- 访客统计 -->
  <div class="wx-visitor">
    <Icon name="material-symbols:visibility-outline" class="wx-visitor-icon" />
    <span class="waline-count" data-path="/moments/">-</span>
    <span>次浏览</span>
  </div>
</MainGridLayout>

<script is:inline>
  var countElements = document.querySelectorAll('.waline-count[data-path="/moments/"]');
  if (countElements.length > 0) {
    var serverURL = "https://co.tsh520.cn";
    fetch(serverURL + "/api/uv?path=/moments/")
      .then(function(res) { return res.json(); })
      .then(function(data) {
        var count = data.data ? data.data.unique_visitor || data.uv || 0 : (data.uv || 0);
        countElements.forEach(function(el) { el.textContent = String(count); });
      })
      .catch(function() {
        countElements.forEach(function(el) { el.textContent = "-"; });
      });
  }
</script>

{externalMomentsConfig.enable && externalMomentsConfig.gistId && (
<script is:inline
  data-gist={externalMomentsConfig.gistId}
  data-file={externalMomentsConfig.fileName}
  data-author={externalMomentsConfig.defaultAuthor}
  data-avatar={externalMomentsConfig.defaultAvatar}>
(function() {
  var _s = document.currentScript;
  var gistId = _s.getAttribute("data-gist");
  var fileName = _s.getAttribute("data-file");
  var defaultAuthor = _s.getAttribute("data-author");
  var defaultAvatar = _s.getAttribute("data-avatar");
  var feed = document.getElementById("moments-feed");
  if (!feed) return;

  var cacheKey = "__externalMomentsCache";
  // 标记：防止 Swup 回退缓存 DOM 后重复插入
  var MARKER = "data-ext-inserted";

  function formatTimeAgo(date) {
    var now = new Date();
    var diff = now - date;
    var minutes = Math.floor(diff / 60000);
    var hours = Math.floor(diff / 3600000);
    var days = Math.floor(diff / 86400000);
    if (minutes < 1) return "刚刚";
    if (minutes < 60) return minutes + "分钟前";
    if (hours < 24) return hours + "小时前";
    if (days < 30) return days + "天前";
    return date.getFullYear() + "-" + String(date.getMonth()+1).padStart(2,"0") + "-" + String(date.getDate()).padStart(2,"0");
  }

  function escapeHtml(text) {
    var div = document.createElement("div"); div.textContent = text; return div.innerHTML;
  }

  function renderMarkdown(text) {
    return escapeHtml(text)
      .replace(/\n/g, "<br>")
      .replace(/\*\*(.*?)\*\*/g, "<strong>$1</strong>")
      .replace(/\*(.*?)\*/g, "<em>$1</em>")
      .replace(/(https?:\/\/[^\s<]+)/g, '<a href="$1" target="_blank" rel="noopener" style="color:var(--primary);text-decoration:underline;">$1</a>');
  }

  function getGridCols(count) {
    if (count === 1) return 1;
    if (count === 2 || count === 4) return 2;
    return 3;
  }

  function parseImages(raw) {
    if (!raw) return [];
    if (Array.isArray(raw)) return raw.filter(Boolean);
    if (typeof raw === "string" && raw.trim()) {
      return raw.split(/[,;]/).map(function(s) { return s.trim(); }).filter(Boolean);
    }
    return [];
  }

  // 将外部说说渲染为 DOM 元素（和 MomentCard.astro 结构一致）
  function createCard(m) {
    var author = m.author || defaultAuthor;
    var avatar = m.avatar || defaultAvatar;
    var date = new Date(m.published);
    var timeStr = formatTimeAgo(date);
    var content = renderMarkdown(m.content || "");
    var images = parseImages(m.images);
    var tags = m.tags || [];
    var location = m.location || "";

    var item = document.createElement("div");
    item.className = "wx-feed-item";
    item.setAttribute("data-published", date.toISOString());
    item.setAttribute(MARKER, "1");

    var card = document.createElement("div");
    card.className = "moment-card";

    // accent bar
    var accent = document.createElement("div");
    accent.className = "card-accent-bar";
    card.appendChild(accent);

    // header
    var header = document.createElement("div");
    header.className = "card-header";

    var avatarDiv = document.createElement("div");
    avatarDiv.className = "card-avatar";
    var avatarImg = document.createElement("img");
    avatarImg.src = avatar;
    avatarImg.alt = author;
    avatarImg.className = "avatar-img";
    avatarImg.loading = "lazy";
    avatarDiv.appendChild(avatarImg);

    var userInfo = document.createElement("div");
    userInfo.className = "card-user-info";

    var userRow = document.createElement("div");
    userRow.className = "user-row";
    var userName = document.createElement("span");
    userName.className = "user-name";
    userName.textContent = author;
    userRow.appendChild(userName);
    if (m.pinned) {
      var badge = document.createElement("span");
      badge.className = "pinned-badge";
      badge.innerHTML = '<svg class="pinned-icon" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 17v5"/><path d="M9 10.76a2 2 0 0 1-1.11 1.79l-1.78.9A2 2 0 0 0 5 15.24V17h14v-1.76a2 2 0 0 0-1.11-1.79l-1.78-.9A2 2 0 0 1 15 10.76V6a1 1 0 0 1 1-1h1a1 1 0 0 0 0-8H7a1 1 0 0 0 0 8h1a1 1 0 0 1 1 1z"/></svg>';
      var badgeText = document.createElement("span");
      badgeText.textContent = "置顶";
      badge.appendChild(badgeText);
      userRow.appendChild(badge);
    }

    var metaRow = document.createElement("div");
    metaRow.className = "meta-row";
    var time = document.createElement("time");
    time.textContent = timeStr;
    metaRow.appendChild(time);
    if (location) {
      var dot = document.createElement("span");
      dot.className = "meta-dot";
      dot.textContent = "·";
      metaRow.appendChild(dot);
      var loc = document.createElement("span");
      loc.className = "location";
      loc.innerHTML = '<svg class="location-icon" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/><circle cx="12" cy="10" r="3"/></svg>';
      var locText = document.createTextNode(location);
      loc.appendChild(locText);
      metaRow.appendChild(loc);
    }

    userInfo.appendChild(userRow);
    userInfo.appendChild(metaRow);
    header.appendChild(avatarDiv);
    header.appendChild(userInfo);
    card.appendChild(header);

    // content
    var contentDiv = document.createElement("div");
    contentDiv.className = "card-content";
    var markdownDiv = document.createElement("div");
    markdownDiv.className = "moment-markdown";
    markdownDiv.style.cssText = "color:var(--text-color);font-size:0.9375rem;line-height:1.75;";
    markdownDiv.innerHTML = content;
    contentDiv.appendChild(markdownDiv);
    card.appendChild(contentDiv);

    // images
    if (images.length > 0) {
      var cols = getGridCols(images.length);
      var imagesDiv = document.createElement("div");
      imagesDiv.className = "card-images image-cols-" + cols;
      images.slice(0, 9).forEach(function(url, i) {
        var imgItem = document.createElement("div");
        imgItem.className = "image-item";
        var img = document.createElement("img");
        img.src = url;
        img.alt = "";
        img.className = "image-img";
        img.loading = "lazy";
        img.setAttribute("data-fancybox", "gallery-ext-" + m.id);
        img.onerror = function() { imgItem.style.display = "none"; };
        imgItem.appendChild(img);
        if (i === 8 && images.length > 9) {
          var overlay = document.createElement("div");
          overlay.className = "more-overlay";
          var moreText = document.createElement("span");
          moreText.className = "more-text";
          moreText.textContent = "+" + (images.length - 8);
          overlay.appendChild(moreText);
          imgItem.appendChild(overlay);
        }
        imagesDiv.appendChild(imgItem);
      });
      card.appendChild(imagesDiv);
    }

    // tags
    if (tags.length > 0) {
      var tagsDiv = document.createElement("div");
      tagsDiv.className = "card-tags";
      tags.forEach(function(t) {
        var tagText = t.trim();
        var a = document.createElement("a");
        a.href = "/archive/?tag=" + encodeURIComponent(tagText);
        a.className = "tag-item";
        a.textContent = "#" + tagText;
        tagsDiv.appendChild(a);
      });
      card.appendChild(tagsDiv);
    }

    item.appendChild(card);
    return item;
  }

  // 为置顶块创建缩略图预览（和 SSR 端结构一致）
  function createPinnedPreview(m) {
    var images = parseImages(m.images);
    var body = m.content || "";
    var preview = document.createElement("div");
    preview.className = "wx-pinned-preview";

    if (images.length > 0) {
      var count = Math.min(images.length, 9);
      var gridDiv = document.createElement("div");
      gridDiv.className = "wx-pimgs wx-pimgs-" + count;
      images.slice(0, 9).forEach(function(src) {
        var img = document.createElement("img");
        img.src = src;
        img.alt = "";
        img.className = "wx-pinned-img";
        img.loading = "lazy";
        gridDiv.appendChild(img);
      });
      preview.appendChild(gridDiv);
    } else {
      var p = document.createElement("p");
      p.className = "wx-ptxt";
      var text = body.slice(0, 60);
      if (body.length > 60) text += "...";
      p.textContent = text;
      preview.appendChild(p);
    }
    return preview;
  }

  // 按时间顺序将外部说说插入到主 feed 中，置顶的插入置顶块
  function insertExternalMoments(extMoments) {
    if (!extMoments || extMoments.length === 0) return;
    extMoments.sort(function(a, b) { return new Date(b.published) - new Date(a.published); });

    // 分离置顶和非置顶
    var pinned = [];
    var normal = [];
    extMoments.forEach(function(m) {
      if (m.pinned) { pinned.push(m); } else { normal.push(m); }
    });

    // 处理外部置顶说说 → 插入置顶块
    if (pinned.length > 0) {
      var pinnedBlock = document.getElementById("pinned-block");
      var pinnedItems = document.getElementById("pinned-items");
      if (pinnedBlock && pinnedItems) {
        pinnedBlock.style.display = "";
        pinned.forEach(function(m) {
          var el = createPinnedPreview(m);
          el.setAttribute(MARKER, "1");
          pinnedItems.appendChild(el);
        });
      }
    }

    // 移除空状态提示
    var emptyEl = document.getElementById("moments-empty");
    if (emptyEl) emptyEl.remove();

    // 收集现有本地说说的时间戳
    var localItems = feed.querySelectorAll(".wx-feed-item[data-published]");
    var localTimes = [];
    localItems.forEach(function(el) {
      localTimes.push({ el: el, time: new Date(el.getAttribute("data-published")).getTime() });
    });

    normal.forEach(function(m) {
      var card = createCard(m);
      var extTime = new Date(m.published).getTime();
      var inserted = false;
      // 找到第一个发布时间更早的本地说说，插在它前面
      for (var i = 0; i < localTimes.length; i++) {
        if (localTimes[i].time < extTime) {
          feed.insertBefore(card, localTimes[i].el);
          inserted = true;
          break;
        }
      }
      if (!inserted) {
        feed.appendChild(card);
      }
    });
  }

  // 检查是否已有外部说说（Swup 回退缓存 DOM 时避免重复）
  function hasExternalMoments() {
    return feed.hasAttribute(MARKER) ||
      feed.querySelector("[" + MARKER + "]") !== null;
  }

  function fetchMoments() {
    // 如果已有外部说说（Swup 缓存恢复），跳过
    if (hasExternalMoments()) return;

    // 检查内存缓存（5分钟内有效）
    if (window[cacheKey] && window[cacheKey].time > Date.now() - 300000) {
      insertExternalMoments(window[cacheKey].data);
      feed.setAttribute(MARKER, "1");
      return;
    }

    var token = localStorage.getItem("gh_moments_token") || "";
    var headers = { "Accept": "application/vnd.github+json" };
    if (token) headers["Authorization"] = "Bearer " + token;

    fetch("https://api.github.com/gists/" + gistId, { headers: headers })
      .then(function(r) {
        if (!r.ok) throw new Error("HTTP " + r.status);
        return r.json();
      })
      .then(function(gist) {
        var file = gist.files[fileName];
        if (!file) return;
        var moments = JSON.parse(file.content || "[]");
        if (!moments.length) return;
        window[cacheKey] = { data: moments, time: Date.now() };
        insertExternalMoments(moments);
        feed.setAttribute(MARKER, "1");
      })
      .catch(function(e) {
        console.warn("[外部说说] 加载失败:", e.message);
      });
  }

  // 首次加载：立即获取
  fetchMoments();

  // Swup 页面切换后：从缓存恢复（仅当 DOM 中没有外部说说时）
  document.addEventListener("swup:content:replace", function() {
    // Swup 回退时 DOM 已有外部说说 → 跳过
    if (hasExternalMoments()) return;
    // 重新获取
    fetchMoments();
  });
})();
</script>
)}

<style>
  /* 置顶块样式在底部 <style is:global> 中，
     因为 JS 动态创建的外部置顶元素没有 Astro scoped 属性 */

  /* ============================================
   * 说说列表
   * ============================================ */
  .wx-feed {
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
    padding: 1rem 0 2rem;
  }

  .wx-feed-item {
    position: relative;
  }

  .wx-feed-item + .wx-feed-item::before {
    content: '';
    position: absolute;
    top: -0.75rem;
    left: 1rem;
    right: 1rem;
    height: 1px;
    background: var(--border);
    opacity: 0.7;
  }

  /* 空状态 */
  .wx-empty {
    text-align: center;
    padding: 3rem 1rem;
    background: var(--card-bg);
    border: 1px solid var(--border);
    border-radius: 12px;
  }

  .wx-empty-icon {
    width: 4rem;
    height: 4rem;
    margin: 0 auto 1rem;
    display: flex;
    align-items: center;
    justify-content: center;
    background: var(--btn-regular-bg);
    border-radius: 50%;
    color: var(--content-meta);
    font-size: 2rem;
  }

  .wx-empty h3 {
    font-size: 1rem;
    font-weight: 600;
    color: var(--text-color);
    margin-bottom: 0.375rem;
  }

  .wx-empty p {
    font-size: 0.875rem;
    color: var(--content-meta);
    margin: 0;
  }

  /* 访客统计 */
  .wx-visitor {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 0.375rem;
    margin: 1.5rem auto 0;
    padding: 0.75rem;
    color: var(--content-meta);
    font-size: 0.8125rem;
  }

  .wx-visitor-icon {
    font-size: 1rem;
  }

  /* 响应式 */
  @media (max-width: 480px) {
    .wx-feed {
      gap: 1.25rem;
      padding: 0.75rem 0 1.5rem;
    }

    .wx-feed-item + .wx-feed-item::before {
      top: -0.625rem;
      left: 0.75rem;
      right: 0.75rem;
    }
  }
</style>

<style is:global>
  /* ============================================
   * 置顶块样式（需要 is:global，
   * 因为 JS 动态创建的外部置顶元素没有 Astro scoped 属性）
   * ============================================ */
  .wx-pinned {
    display: flex;
    align-items: stretch;
    background: var(--card-bg);
    border-radius: 12px;
    overflow: hidden;
    margin-bottom: 1.25rem;
    min-height: 4.5rem;
    text-decoration: none;
    color: var(--text-color);
    border: 1.5px solid transparent;
    transition: border-color 0.2s ease, transform 0.2s ease;
    cursor: pointer;
  }
  .wx-pinned:hover {
    border-color: var(--primary);
    transform: translateY(-2px);
  }
  .wx-pinned-tag {
    display: flex;
    align-items: center;
    gap: 0.25rem;
    padding: 0 0.75rem;
    background: #fff;
    color: #1a1a1a;
    font-size: 1.625rem;
    font-weight: 400;
    flex-shrink: 0;
    white-space: nowrap;
  }
  :root.dark .wx-pinned-tag {
    background: #000;
    color: #fff;
  }
  .wx-pinned-items {
    display: flex;
    flex: 1;
    justify-content: flex-end;
    overflow-x: auto;
    overflow-y: hidden;
    scrollbar-width: none;
    gap: 0;
  }
  .wx-pinned-items::-webkit-scrollbar {
    display: none;
  }
  .wx-pinned-preview {
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 0.5rem;
    min-width: 4rem;
    max-width: 7.5rem;
    flex: 1;
    border-left: 1px solid var(--border);
    overflow: hidden;
  }
  .wx-pinned-preview:first-child {
    border-left: none;
  }
  .wx-pimgs {
    display: grid;
    gap: 2px;
    width: 100%;
    aspect-ratio: 1;
    border-radius: 4px;
    overflow: hidden;
  }
  .wx-pimgs-1 { grid-template-columns: 1fr; }
  .wx-pimgs-2 { grid-template-columns: 1fr 1fr; }
  .wx-pimgs-3 {
    grid-template-columns: 1fr 1fr;
    grid-template-rows: 1fr 1fr;
  }
  .wx-pimgs-3 .wx-pinned-img:first-child { grid-row: 1 / 3; }
  .wx-pimgs-4 {
    grid-template-columns: 1fr 1fr;
    grid-template-rows: 1fr 1fr;
  }
  .wx-pimgs-5,
  .wx-pimgs-6 {
    grid-template-columns: 1fr 1fr 1fr;
    grid-template-rows: 1fr 1fr;
  }
  .wx-pimgs-7,
  .wx-pimgs-8,
  .wx-pimgs-9 {
    grid-template-columns: 1fr 1fr 1fr;
    grid-template-rows: 1fr 1fr 1fr;
  }
  .wx-pinned-img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }
  .wx-ptxt {
    margin: 0;
    font-size: 0.625rem;
    color: var(--content-meta);
    line-height: 1.5;
    display: -webkit-box;
    -webkit-line-clamp: 4;
    -webkit-box-orient: vertical;
    overflow: hidden;
    word-break: break-all;
  }
  @media (max-width: 480px) {
    .wx-pinned-preview {
      min-width: 3.5rem;
      max-width: 6rem;
      padding: 0.375rem;
    }
    .wx-ptxt {
      font-size: 0.5625rem;
      -webkit-line-clamp: 3;
    }
  }

