---
import { Icon } from "astro-icon/components";
import Comment from "@/components/comment/index.astro";
import MomentCard from "@/components/moments/MomentCard.astro";
import MomentsCover from "@/components/moments/MomentsCover.astro";
import MainGridLayout from "@layouts/MainGridLayout.astro";
import MomentsEditor from "@/components/edit/MomentsEditor.svelte";
import { momentsCover, getEnabledMoments, momentsPageConfig } from "@/config/momentsConfig";

// 从 momentsConfig.ts 读取说说数据
const allMoments = getEnabledMoments();

const coverImage = momentsCover.cover_image;
const coverAvatar = momentsCover.cover_avatar;
const coverName = momentsCover.cover_name;
const coverBio = momentsCover.cover_bio;

// 置顶说说
const pinnedMoments = allMoments.filter((m) => m.pinned);
// 普通说说（按时间倒序）
const sortedMoments = allMoments.filter((m) => !m.pinned);

// 预处理置顶说说
const pinnedData = pinnedMoments.map((m) => ({
	images: m.images || [],
	body: m.body || "",
	date: new Date(m.published),
}));

const albums = [] as any[];
---

<MainGridLayout title="动态" description="记录生活中的点点滴滴">
  <!-- 微信朋友圈风格封面 -->
  <MomentsCover coverImage={coverImage} coverAvatar={coverAvatar} coverName={coverName} coverBio={coverBio} />

  <!-- 置顶说说（始终渲染容器，JS 可动态追加外部置顶） -->
  <div class="wx-pinned" id="pinned-block" style={pinnedMoments.length === 0 ? 'display:none' : ''}>
    <a href="/moments/pinned/" class="wx-pinned-link">
      <div class="wx-pinned-tag">
        <span>置顶</span>
      </div>
      <div class="wx-pinned-items" id="pinned-items">
        {pinnedData.map((item) => (
          <div class="wx-pinned-preview">
            {item.images.length > 0 ? (
              <div class={`wx-pimgs wx-pimgs-${Math.min(item.images.length, 9)}`}>
                {item.images.slice(0, 9).map((img) => (
                  <img src={img} alt="" class="wx-pinned-img" loading="lazy" />
                ))}
              </div>
            ) : (
              <p class="wx-ptxt">{item.body.slice(0, 60)}{item.body.length > 60 ? '...' : ''}</p>
            )}
          </div>
        ))}
      </div>
    </a>
    <!-- 隐藏的完整卡片供编辑组件收集数据 -->
    <div class="wx-pinned-hidden">
      {pinnedMoments.map((moment) => (
        <MomentCard moment={moment} />
      ))}
    </div>
  </div>

  <!-- 说说列表（本地 + 外部合并，按时间排序） -->
  <div class="wx-feed" id="moments-feed">
    {sortedMoments.length > 0 ? (
      sortedMoments.map((moment) => (
        <div class="wx-feed-item" data-published={new Date(moment.published).toISOString()}>
          <MomentCard moment={moment} />
        </div>
      ))
    ) : (
      <div class="wx-empty" id="moments-empty">
        <div class="wx-empty-icon">
          <Icon name="material-symbols:sentiment-neutral-outline" />
        </div>
        <h3>还没有发布任何说说</h3>
        <p>快去记录你的生活点滴吧</p>
      </div>
    )}
  </div>

  <MomentsEditor client:load />

  <!-- 评论区 -->
  <div id="moments-comments">
    <Comment customPath="/moments/" />
  </div>

  <!-- 访客统计 -->
  <div class="wx-visitor">
    <Icon name="material-symbols:visibility-outline" class="wx-visitor-icon" />
    <span class="waline-count" data-path="/moments/">-</span>
    <span>次浏览</span>
  </div>
</MainGridLayout>

<script is:inline>
  var countElements = document.querySelectorAll('.waline-count[data-path="/moments/"]');
  if (countElements.length > 0) {
    var serverURL = "https://co.tsh520.cn";
    fetch(serverURL + "/api/uv?path=/moments/")
      .then(function(res) { return res.json(); })
      .then(function(data) {
        var count = data.data ? data.data.unique_visitor || data.uv || 0 : (data.uv || 0);
        countElements.forEach(function(el) { el.textContent = String(count); });
      })
      .catch(function() {
        countElements.forEach(function(el) { el.textContent = "-"; });
      });
  }
</script>


<style>
  /* 置顶块样式在底部 <style is:global> 中，
     因为 JS 动态创建的外部置顶元素没有 Astro scoped 属性 */

  /* ============================================
   * 说说列表
   * ============================================ */
  .wx-feed {
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
    padding: 1rem 0 2rem;
  }

  .wx-feed-item {
    position: relative;
  }

  .wx-feed-item + .wx-feed-item::before {
    content: '';
    position: absolute;
    top: -0.75rem;
    left: 1rem;
    right: 1rem;
    height: 1px;
    background: var(--border);
    opacity: 0.7;
  }

  /* 空状态 */
  .wx-empty {
    text-align: center;
    padding: 3rem 1rem;
    background: var(--card-bg);
    border: 1px solid var(--border);
    border-radius: 12px;
  }

  .wx-empty-icon {
    width: 4rem;
    height: 4rem;
    margin: 0 auto 1rem;
    display: flex;
    align-items: center;
    justify-content: center;
    background: var(--btn-regular-bg);
    border-radius: 50%;
    color: var(--content-meta);
    font-size: 2rem;
  }

  .wx-empty h3 {
    font-size: 1rem;
    font-weight: 600;
    color: var(--text-color);
    margin-bottom: 0.375rem;
  }

  .wx-empty p {
    font-size: 0.875rem;
    color: var(--content-meta);
    margin: 0;
  }

  /* 访客统计 */
  .wx-visitor {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 0.375rem;
    margin: 1.5rem auto 0;
    padding: 0.75rem;
    color: var(--content-meta);
    font-size: 0.8125rem;
  }

  .wx-visitor-icon {
    font-size: 1rem;
  }

  /* 响应式 */
  @media (max-width: 480px) {
    .wx-feed {
      gap: 1.25rem;
      padding: 0.75rem 0 1.5rem;
    }

    .wx-feed-item + .wx-feed-item::before {
      top: -0.625rem;
      left: 0.75rem;
      right: 0.75rem;
    }
  }
</style>

