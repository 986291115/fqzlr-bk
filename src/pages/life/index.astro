---
import MainGridLayout from "@/layouts/MainGridLayout.astro";
import { getCollection } from "astro:content";
import { Icon } from "astro-icon/components";
import { url } from "@/utils/url-utils";
import { marked } from "marked";

const allLifeEntries = await getCollection("life");
const isIn = (entryId, folder) => entryId.replace(/\\/g, "/").startsWith(folder + "/");

const ideas = allLifeEntries
  .filter(e => isIn(e.id, "ideas") && !e.id.toLowerCase().includes("readme"))
  .map(e => ({
    id: e.id, type: "想法", icon: "material-symbols:lightbulb-outline",
    color: "#f59e0b", bgColor: "rgba(245, 158, 11, 0.1)",
    date: e.data.completedAt || e.data.createdAt,
    createdAt: e.data.createdAt, completedAt: e.data.completedAt,
    isCompleted: !!e.data.completedAt,
    content: e.data.content || "无内容",
    label: e.data.label, href: "/life/ideas/",
  }));

const workouts = await getCollection("lifeWorkout");
const workoutEntries = workouts.map(e => ({
  id: e.id, type: "运动", icon: "material-symbols:directions-run",
  color: "#3b82f6", bgColor: "rgba(59, 130, 246, 0.1)",
  date: e.data.date, workoutType: e.data.workoutType || "运动",
  runKm: e.data.runKm || 0, workoutMinutes: e.data.workoutMinutes || 0,
  stepsToday: e.data.stepsToday || 0, note: e.data.note, href: "/life/health/",
}));

const sleepEntries = await getCollection("lifeSleep");
const sleepData = sleepEntries.map(e => ({
  id: e.id, type: "睡眠", icon: "material-symbols:bedtime-outline",
  color: "#8b5cf6", bgColor: "rgba(139, 92, 246, 0.1)",
  date: e.data.date, sleepHours: e.data.sleepHours || 0,
  sleepQuality: e.data.sleepQuality || 3, sleepTime: e.data.sleepTime,
  wakeTime: e.data.wakeTime, dream: e.data.dream, note: e.data.note,
  href: "/life/health/",
}));

const foodEntries = await getCollection("lifeFood");
const foodData = foodEntries.map(e => ({
  id: e.id, type: "饮食", icon: "material-symbols:lunch-dining",
  color: "#f97316", bgColor: "rgba(249, 115, 22, 0.1)",
  date: e.data.date, name: e.data.name || "饮食记录",
  breakfast: e.data.breakfast, lunch: e.data.lunch, dinner: e.data.dinner,
  snack: e.data.snack, allowedFoods: e.data.allowedFoods || [],
  avoidFoods: e.data.avoidFoods || [], water: e.data.water,
  weight: e.data.weight, note: e.data.note, href: "/life/health/",
}));

const checkinEntries = await getCollection("checkin");
const checkinData = checkinEntries
  .filter(e => !e.id.toLowerCase().includes("readme"))
  .map(e => ({
    id: e.id, type: "打卡", icon: "material-symbols:check-circle-outline",
    color: "#84cc16", bgColor: "rgba(132, 204, 22, 0.1)",
    date: e.data.updatedAt || e.data.checkins?.[e.data.checkins.length - 1],
    updatedAt: e.data.updatedAt, name: e.data.name || "打卡",
    description: e.data.description, checkins: e.data.checkins || [],
    href: "/life/checkin/",
  }));

const routinesRaw = await getCollection("routines");
const routinesFiltered = routinesRaw.filter(e => !e.id.toLowerCase().includes("readme"));
const routinesData = await Promise.all(routinesFiltered.map(async e => {
  const bodyText = e.body ? e.body.split("\n").filter(l => !l.trim().match(/^-{3}$/)).join("\n").trim() : "";
  return {
    id: e.id, type: "规划", icon: undefined, emoji: e.data.icon,
    color: e.data.color || "#06b6d4", bgColor: "rgba(6, 182, 212, 0.1)",
    date: e.data.updatedAt, name: e.data.name || "规划",
    time: e.data.time, description: e.data.description, body: bodyText,
    href: "/life/routines/",
  };
}));

const placesData = allLifeEntries
  .filter(e => isIn(e.id, "places") && !e.id.toLowerCase().includes("readme"))
  .map(e => ({
    id: e.id, type: "足迹", icon: "material-symbols:location-on-outline",
    color: "#10b981", bgColor: "rgba(16, 185, 129, 0.1)",
    date: e.data.date, province: e.data.province, city: e.data.city,
    district: e.data.district, visitCount: e.data.visitCount || 1,
    experience: e.data.experience, href: "/life/places/",
  }));

const notebooksRaw = await getCollection("notebooks");

// 首先收集所有笔记本文件夹的名称映射
const notebookNameMap = new Map();
notebooksRaw.forEach(entry => {
  const normalizedId = entry.id.replace(/\\/g, "/");
  // 匹配 _index 文件来获取笔记本名称
  const isIndexFile = normalizedId.match(/^([^/]+)\/(_index|_index\.md|_index\.json)$/);
  if (isIndexFile) {
    const folderName = isIndexFile[1];
    notebookNameMap.set(folderName, entry.data.name || folderName);
  }
});

const notebookEntries = notebooksRaw
  .filter(e => { const id = e.id.replace(/\\/g, "/"); return !id.endsWith("/_index"); })
  .sort((a, b) => { const aT = a.data.date instanceof Date ? a.data.date.getTime() : 0; const bT = b.data.date instanceof Date ? b.data.date.getTime() : 0; return bT - aT; });

const notebookData = notebookEntries.map(e => {
  const normalizedId = e.id.replace(/\\/g, "/");
  const folderName = normalizedId.split("/")[0];
  const notebookName = notebookNameMap.get(folderName) || folderName;
  return {
    id: e.id, 
    notebookName,  // 笔记本名称，如"我的宝宝"
    type: "笔记", 
    icon: "material-symbols:edit-note",
    color: "#ec4899", 
    bgColor: "rgba(236, 72, 153, 0.1)",
    date: e.data.date, 
    entryName: e.data.name || "未命名",  // 日记标题，如"我和宝宝"
    href: `/life/notebooks/${folderName}/`,
  };
});

const allItems = [...ideas, ...workoutEntries, ...sleepData, ...foodData, ...checkinData, ...routinesData, ...placesData, ...notebookData]
  .filter(i => i.date instanceof Date && !Number.isNaN(i.date.getTime()))
  .sort((a, b) => { const aT = a.date instanceof Date ? a.date.getTime() : 0; const bT = b.date instanceof Date ? b.date.getTime() : 0; return bT - aT; });

function formatDate(date) { if (!date) return ""; const d = date instanceof Date ? date : new Date(String(date)); if (Number.isNaN(d.getTime())) return ""; return d.toISOString().split("T")[0]; }
function formatTimeAgo(date) { const now = new Date(); const diff = now.getTime() - date.getTime(); const mins = Math.floor(diff / 60000); const hrs = Math.floor(diff / 3600000); const days = Math.floor(diff / 86400000); if (mins < 1) return "刚刚"; if (mins < 60) return mins + " 分钟前"; if (hrs < 24) return hrs + " 小时前"; if (days < 30) return days + " 天前"; return formatDate(date); }

const navItems = [
  { label: "笔记本", icon: "material-symbols:book-outline", href: "/life/notebooks/", color: "#ec4899" },
  { label: "规划", icon: "material-symbols:schedule-outline", href: "/life/routines/", color: "#06b6d4" },
  { label: "想法", icon: "material-symbols:lightbulb-outline", href: "/life/ideas/", color: "#f59e0b" },
  { label: "足迹", icon: "material-symbols:location-on-outline", href: "/life/places/", color: "#10b981" },
  { label: "健康", icon: "material-symbols:favorite-outline", href: "/life/health/", color: "#3b82f6" },
  { label: "打卡", icon: "material-symbols:check-circle-outline", href: "/life/checkin/", color: "#84cc16" },
];

const totalWorkouts = workoutEntries.length;
const totalRunKm = workoutEntries.reduce((acc, i) => acc + i.runKm, 0);
const totalIdeas = ideas.length;
const totalCheckins = checkinEntries.reduce((acc, i) => acc + (i.data?.checkins?.length || 0), 0);
---

<MainGridLayout title="生活" description="用心记录每一天">
  <div class="life-container">
    <div class="nav-tabs-wrapper" id="life-nav-wrapper">
      <div class="nav-container">
        <!-- 左侧固定的"生活"按钮 -->
        <a href={url("/life/")} class="nav-tab nav-tab-home" data-category-name="生活">
          <Icon name="material-symbols:favorite" class="tab-icon" />
          <span class="tab-label">生活</span>
        </a>
        <!-- 右侧可滚动区域 -->
        <div class="nav-tabs-scroll" id="life-nav-tabs-scroll">
          <div class="nav-tabs" id="life-nav-tabs">
            {navItems.map(item => (
              <a 
                href={url(item.href)} 
                class="nav-tab" 
                data-category-name={item.label}
              >
                <Icon name={item.icon} class="tab-icon" />
                <span class="tab-label">{item.label}</span>
              </a>
            ))}
          </div>
        </div>
      </div>
    </div>
    <div class="life-feed">
      {allItems.length === 0 ? (
        <div class="empty-state">
          <div class="empty-icon">
            <Icon name="material-symbols:sentiment-neutral-outline" />
          </div>
          <h3 class="empty-title">还没有生活记录</h3>
          <p class="empty-desc">选择一个模块，开始记录你的生活吧！</p>
        </div>
      ) : (
        allItems.map(item => {
          const iconStyle = `background: ${item.bgColor}`;
          const iconColorStyle = `color: ${item.color}`;
          const typeLabelStyle = `color: ${item.color}; background: ${item.bgColor}`;
          
          // 统一的摘要生成函数
          let summary = "";
          let subInfo = "";
          let typeLabel = item.type; // 默认使用 item.type
          
          if (item.type === "想法") {
            summary = item.content;
            subInfo = item.isCompleted ? "✓ 已完成" : "○ 待完成";
          } else if (item.type === "运动") {
            summary = item.workoutType || "运动记录";
            subInfo = `${item.runKm.toFixed(1)} km · ${item.workoutMinutes} 分钟`;
          } else if (item.type === "睡眠") {
            summary = "睡眠记录";
            subInfo = `${item.sleepHours} 小时 · 质量 ${"★".repeat(item.sleepQuality)}${"☆".repeat(5 - item.sleepQuality)}`;
          } else if (item.type === "饮食") {
            // 主要内容显示日期
            summary = formatDate(item.date);
            // 次要信息显示饮食情况
            const foodTags = [];
            if (item.allowedFoods?.length > 0) {
              foodTags.push(`<span class="food-tag allowed">✓ ${item.allowedFoods.join(", ")}</span>`);
            }
            if (item.avoidFoods?.length > 0) {
              foodTags.push(`<span class="food-tag avoid">✗ ${item.avoidFoods.join(", ")}</span>`);
            }
            subInfo = foodTags.length > 0 ? foodTags.join("") : (item.weight ? `体重 ${item.weight}` : "无饮食记录");
            // 特殊处理饮食类型，subInfo 需要 HTML
            item._renderFoodSubInfo = true;
          } else if (item.type === "打卡") {
            summary = item.name || "打卡";
            subInfo = `累计 ${item.checkins?.length || 0} 天`;
          } else if (item.type === "规划") {
            summary = item.name || "规划";
            subInfo = item.time || "";
          } else if (item.type === "足迹") {
            summary = [item.province, item.city, item.district].filter(Boolean).join(" ");
            subInfo = item.experience?.slice(0, 30) || `到访 ${item.visitCount} 次`;
          } else if (item.type === "笔记") {
            summary = item.entryName || "未命名";
            subInfo = "";
          }
          
          return (
            <a href={url(item.href)} class="life-card">
              <div class="life-card-header">
                <div class="life-card-type">
                  <span class="type-icon" style={iconColorStyle}>
                    <Icon name={item.icon || "material-symbols:circle"} size={18} />
                  </span>
                  <span class="type-label" style={typeLabelStyle}>{typeLabel}</span>
                </div>
                <time class="life-card-time" datetime={item.date instanceof Date ? item.date.toISOString() : String(item.date)}>
                  {formatTimeAgo(item.date)}
                </time>
              </div>
              <div class="life-card-content">
                <div class="life-card-title">{summary}</div>
                {subInfo && (
                  item._renderFoodSubInfo ? (
                    <div class="life-card-sub food-tags" set:html={subInfo} />
                  ) : (
                    <div class="life-card-sub">{subInfo}</div>
                  )
                )}
              </div>
              <div class="life-card-arrow">
                <Icon name="material-symbols:chevron-right-rounded" size={20} />
              </div>
            </a>
          );
        })
      )}
    </div>
  </div>
</MainGridLayout>

<style>
  .life-container { margin: 0 auto; padding: 0 16px 40px; }

  /* 导航标签样式 */
  .nav-tabs-wrapper { 
    margin-bottom: 16px; 
    overflow: hidden; 
    position: relative;
  }
  .nav-tabs-wrapper::before,
  .nav-tabs-wrapper::after {
    content: '';
    position: absolute;
    top: 0;
    bottom: 0;
    width: 32px;
    z-index: 2;
    pointer-events: none;
    opacity: 0;
    transition: opacity 0.2s;
  }
  .nav-tabs-wrapper::before {
    left: 0;
    background: linear-gradient(to right, var(--card-bg), transparent);
  }
  .nav-tabs-wrapper::after {
    right: 0;
    background: linear-gradient(to left, var(--card-bg), transparent);
  }
  .nav-tabs-wrapper.show-left::before { opacity: 1; }
  .nav-tabs-wrapper.show-right::after { opacity: 1; }
  
  .nav-container {
    display: flex;
    align-items: center;
    gap: 0;
    background: var(--card-bg);
    border: 1px solid var(--line-divider);
    border-radius: 12px;
    padding: 6px;
  }
  
  .nav-tab-home {
    flex-shrink: 0;
    background: var(--card-bg);
  }
  
  .nav-tabs-scroll {
    flex: 1;
    min-width: 0;
    position: relative;
    overflow: hidden;
  }
  
  .nav-tabs { 
    display: flex; 
    gap: 6px; 
    padding: 2px;
    overflow-x: auto;
    scroll-behavior: smooth;
    scrollbar-width: none;
    -ms-overflow-style: none;
    -webkit-overflow-scrolling: touch;
  }
  .nav-tabs::-webkit-scrollbar { display: none; }
  
  .nav-tab {
    flex-shrink: 0; 
    display: flex; 
    align-items: center; 
    justify-content: center;
    gap: 6px; 
    padding: 6px 14px; 
    border-radius: 8px; 
    font-size: 14px; 
    font-weight: 500; 
    text-decoration: none; 
    transition: all 0.2s ease;
    white-space: nowrap;
    background: transparent;
    border: 1.5px solid var(--line-divider);
    color: var(--btn-content);
  }
  .nav-tab:hover { 
    border-color: var(--primary);
    color: var(--primary);
    background: transparent;
  }
  .nav-tab[data-active] {
    background: var(--primary);
    border-color: var(--primary);
    color: white;
  }
  .nav-tab[data-active]:hover {
    opacity: 0.9;
    transform: none;
    box-shadow: none;
  }
  .nav-tab:active {
    transform: scale(0.98);
  }
  .tab-icon { font-size: 18px; }

  /* ===== 简洁风格卡片 ===== */
  .life-feed {
    display: flex;
    flex-direction: column;
    gap: 12px;
  }

  .life-card {
    display: flex;
    align-items: center;
    gap: 16px;
    padding: 16px 20px;
    background: var(--card-bg);
    border: 1px solid var(--border);
    border-radius: 12px;
    text-decoration: none;
    color: inherit;
    transition: all 0.2s ease;
  }

  .life-card:hover {
    border-color: var(--primary);
    background: var(--bg-color);
  }

  .life-card-header {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    gap: 8px;
    min-width: 90px;
  }

  .life-card-type {
    display: flex;
    align-items: center;
    gap: 6px;
  }

  .type-icon {
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .type-label {
    display: inline-flex;
    align-items: center;
    padding: 4px 10px;
    border-radius: 6px;
    font-size: 12px;
    font-weight: 600;
  }

  .life-card-time {
    font-size: 12px;
    color: var(--content-meta);
    padding-left: 24px;
  }

  .life-card-content {
    flex: 1;
    min-width: 0;
    display: flex;
    flex-direction: column;
    gap: 4px;
  }

  .life-card-title {
    font-size: 15px;
    font-weight: 500;
    color: var(--text-color);
    line-height: 1.5;
    word-break: break-word;
  }

  .life-card-sub {
    font-size: 13px;
    color: var(--content-meta);
    line-height: 1.4;
  }

  .life-card-arrow {
    flex-shrink: 0;
    color: var(--content-meta);
    opacity: 0;
    transition: all 0.2s ease;
  }

  .life-card:hover .life-card-arrow {
    opacity: 1;
    color: var(--primary);
  }

  /* 饮食标签样式 */
  .food-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 6px;
  }

  .food-tag {
    display: inline-flex;
    align-items: center;
    gap: 4px;
    padding: 4px 10px;
    border-radius: 12px;
    font-size: 12px;
    font-weight: 500;
  }

  .food-tag.allowed {
    background: rgba(34, 197, 94, 0.15);
    color: #16a34a;
  }

  .food-tag.avoid {
    background: rgba(239, 68, 68, 0.15);
    color: #dc2626;
  }

  :global(html.dark) .food-tag.allowed {
    color: #4ade80;
  }

  :global(html.dark) .food-tag.avoid {
    color: #f87171;
  }

  /* 空状态 */
  .empty-state {
    text-align: center;
    padding: 60px 20px;
    background: var(--card-bg);
    border: 1px solid var(--border);
    border-radius: 12px;
  }

  .empty-icon {
    width: 64px;
    height: 64px;
    margin: 0 auto 16px;
    display: flex;
    align-items: center;
    justify-content: center;
    background: var(--bg-color);
    border-radius: 50%;
    color: var(--content-meta);
    font-size: 32px;
    opacity: 0.5;
  }

  .empty-title {
    font-size: 16px;
    font-weight: 600;
    color: var(--text-color);
    margin-bottom: 6px;
  }

  .empty-desc {
    font-size: 14px;
    color: var(--content-meta);
  }

  /* 移动端适配 */
  @media (max-width: 768px) {
    .life-container { max-width: 100%; }
    .life-card {
      padding: 14px 16px;
      gap: 12px;
    }
    .life-card-header {
      min-width: 70px;
      gap: 6px;
    }
    .life-card-title {
      font-size: 14px;
    }
    .life-card-sub {
      font-size: 12px;
    }
    .life-card-time {
      font-size: 11px;
    }
  }

  @media (max-width: 480px) {
    .life-container { padding: 0 12px 32px; }
    .life-card {
      flex-wrap: wrap;
      gap: 8px;
    }
    .life-card-header {
      flex-direction: row;
      align-items: center;
      justify-content: space-between;
      width: 100%;
      min-width: unset;
    }
    .life-card-time {
      padding-left: 0;
    }
    .life-card-content {
      width: 100%;
    }
    .life-card-arrow {
      display: none;
    }
  }
</style>

<script>
  document.addEventListener('DOMContentLoaded', initNavTabs);
  document.addEventListener('astro:page-load', initNavTabs);
  
  function initNavTabs() {
    const wrapper = document.getElementById('life-nav-wrapper');
    const tabsScroll = document.getElementById('life-nav-tabs-scroll');
    const tabs = document.getElementById('life-nav-tabs');
    
    if (!wrapper || !tabsScroll || !tabs) return;
    if (tabs.dataset.initialized) return;
    tabs.dataset.initialized = 'true';
    
    // 获取整体容器
    const navContainer = tabsScroll.closest('.nav-container');
    
    // 高亮当前导航项
    function updateActiveNav() {
      const pathname = window.location.pathname;
      const navPills = tabs.querySelectorAll('.nav-tab:not(.nav-tab-home)');
      
      navPills.forEach(pill => {
        pill.removeAttribute('data-active');
        const href = pill.getAttribute('href');
        if (href && pathname.startsWith(href)) {
          pill.setAttribute('data-active', '');
        }
      });
      
      // 生活主页高亮
      const homeTab = tabs.querySelector('.nav-tab-home');
      if (homeTab) {
        homeTab.removeAttribute('data-active');
        if (pathname === '/life/' || pathname === '/life') {
          homeTab.setAttribute('data-active', '');
        }
      }
    }
    
    // 初始化高亮
    updateActiveNav();
    document.addEventListener('swup:contentReplaced', updateActiveNav);
    
    // 滚动到当前高亮的标签
    function scrollToActiveTab() {
      const activeTab = tabs.querySelector('.nav-tab[data-active]');
      if (activeTab) {
        const scrollLeft = activeTab.offsetLeft - tabsScroll.offsetLeft - (tabsScroll.clientWidth - activeTab.offsetWidth) / 2;
        tabs.scrollTo({ left: Math.max(0, scrollLeft), behavior: 'smooth' });
      }
    }
    
    // 高亮更新后滚动到当前标签
    const originalUpdateActiveNav = updateActiveNav;
    updateActiveNav = function() {
      originalUpdateActiveNav();
      scrollToActiveTab();
    };
    
    // 更新滚动阴影指示器
    function updateScrollIndicators() {
      const scrollLeft = tabs.scrollLeft;
      const scrollWidth = tabs.scrollWidth;
      const clientWidth = tabs.clientWidth;
      
      wrapper.classList.toggle('show-left', scrollLeft > 10);
      wrapper.classList.toggle('show-right', scrollLeft < scrollWidth - clientWidth - 10);
    }
    
    // 监听滚动
    tabs.addEventListener('scroll', updateScrollIndicators);
    window.addEventListener('resize', updateScrollIndicators);
    updateScrollIndicators();
    
    // 桌面端：鼠标悬停时滚轮水平滚动
    if (navContainer) {
      navContainer.addEventListener('mouseenter', () => {
        document.body.style.overflow = 'hidden';
      });
      
      navContainer.addEventListener('mouseleave', () => {
        document.body.style.overflow = '';
      });
      
      // 滚轮事件 - 水平滚动
      navContainer.addEventListener('wheel', (e) => {
        if (tabs.scrollWidth > tabs.clientWidth) {
          e.stopPropagation();
          tabs.scrollLeft += e.deltaY + e.deltaX;
          updateScrollIndicators();
        }
      }, { capture: true, passive: false });
    }
    
    // 移动端：触摸滑动
    let touchStartX = 0;
    let touchScrollLeft = 0;
    
    tabs.addEventListener('touchstart', (e) => {
      touchStartX = e.touches[0].pageX;
      touchScrollLeft = tabs.scrollLeft;
    }, { passive: true });
    
    tabs.addEventListener('touchmove', (e) => {
      const touchX = e.touches[0].pageX;
      const walk = (touchStartX - touchX) * 1.5;
      tabs.scrollLeft = touchScrollLeft + walk;
      updateScrollIndicators();
    }, { passive: true });
  }
</script>
