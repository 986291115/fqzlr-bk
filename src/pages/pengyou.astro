---
import { Icon } from "astro-icon/components";
import { pengyouConfig } from "@/config/pengyouConfig";
import MainGridLayout from "@/layouts/MainGridLayout.astro";
import PengyouEditor from "@/components/edit/PengyouEditor.svelte";

const title = "朋友圈";
const description = "来看看我的朋友们都在干嘛";

const { api, rss, data } = pengyouConfig;

interface PengyouItem {
	title: string;
	author: string;
	date: string;
	link: string;
	content: string;
}

let items: PengyouItem[] = data;

function decodeHtmlEntities(str: string): string {
	const entities: { [key: string]: string } = {
		'&lt;': '<',
		'&gt;': '>',
		'&amp;': '&',
		'&quot;': '"',
		'&#39;': "'",
		'&nbsp;': ' ',
	};
	return str.replace(/&[a-z]+;/gi, (match) => entities[match] || match);
}

function parseRSS(xml: string): { title: string; link: string; pubDate: string; description: string; content: string }[] {
	const results: { title: string; link: string; pubDate: string; description: string; content: string }[] = [];
	
	const itemRegex = /<item[^>]*>([\s\S]*?)<\/item>/gi;
	let match;
	
	while ((match = itemRegex.exec(xml)) !== null) {
		const itemContent = match[1];
		
		const titleMatch = itemContent.match(/<title[^>]*>([\s\S]*?)<\/title>/i);
		const linkMatch = itemContent.match(/<link[^>]*>([\s\S]*?)<\/link>/i);
		const pubDateMatch = itemContent.match(/<pubDate[^>]*>([\s\S]*?)<\/pubDate>/i);
		const descMatch = itemContent.match(/<description[^>]*>([\s\S]*?)<\/description>/i);
		const contentMatch = itemContent.match(/<content:encoded[^>]*>([\s\S]*?)<\/content:encoded>/i) || 
							itemContent.match(/<encoded[^>]*>([\s\S]*?)<\/encoded>/i);
		
		let content = (contentMatch ? contentMatch[1] : descMatch ? descMatch[1] : "").trim();
		content = decodeHtmlEntities(content);
		content = content.replace(/<[^>]*>/g, "");
		content = content.replace(/\s+/g, " ").trim();
		if (content.length > 200) {
			content = content.substring(0, 200) + "...";
		}
		
		let title = titleMatch ? titleMatch[1].trim() : "";
		title = decodeHtmlEntities(title);
		title = title.replace(/<[^>]*>/g, "");
		
		if (title && linkMatch) {
			results.push({
				title,
				link: linkMatch[1].trim(),
				pubDate: pubDateMatch ? pubDateMatch[1].trim() : "",
				description: descMatch ? descMatch[1].replace(/<[^>]*>/g, "").trim() : "",
				content: content || "暂无内容",
			});
		}
	}
	
	return results;
}

async function fetchRSS(url: string, author: string): Promise<PengyouItem[]> {
	try {
		const response = await fetch(url);
		if (!response.ok) return [];
		const xml = await response.text();
		
		const parsedItems = parseRSS(xml);
		
		return parsedItems.map(item => ({
			title: item.title,
			author,
			date: item.pubDate,
			link: item.link,
			content: item.content,
		}));
	} catch (e) {
		console.error(`Failed to fetch RSS from ${url}:`, e);
		return [];
	}
}

if (rss && rss.length > 0) {
	const rssItems: PengyouItem[] = [];
	for (const source of rss) {
		if (source.enabled !== false && source.url) {
			const fetched = await fetchRSS(source.url, source.name);
			rssItems.push(...fetched);
		}
	}
	
	rssItems.sort((a, b) => {
		const dateA = new Date(a.date);
		const dateB = new Date(b.date);
		return dateB.getTime() - dateA.getTime();
	});
	
	items = rssItems;
}

if (api && items.length === 0) {
	try {
		const response = await fetch(api);
		if (response.ok) {
			items = await response.json();
		}
	} catch {
		console.error("Failed to fetch friends data from API");
	}
}

function formatDate(dateString: string): string {
	const date = new Date(dateString);
	if (isNaN(date.getTime())) return "未知时间";
	
	const now = new Date();
	const diffTime = Math.abs(now.getTime() - date.getTime());
	const diffDays = Math.floor(diffTime / (1000 * 60 * 60 * 24));

	if (diffDays === 0) return "今天";
	if (diffDays === 1) return "昨天";
	if (diffDays < 7) return `${diffDays}天前`;
	if (diffDays < 30) return `${Math.floor(diffDays / 7)}周前`;
	if (diffDays < 365) return `${Math.floor(diffDays / 30)}月前`;
	return `${Math.floor(diffDays / 365)}年前`;
}
---

<MainGridLayout title={title} description={description}>
	<div class="card-base z-10 px-9 py-6 relative w-full">
		<div class="flex items-center gap-3 mb-6">
			<div class="h-8 w-8 rounded-lg bg-(--primary) flex items-center justify-center text-white dark:text-black/70">
				<Icon name="material-symbols:group" class="text-[1.5rem]" />
			</div>
			<h1 class="text-3xl font-bold text-neutral-900 dark:text-neutral-100">
				{title}
			</h1>
		</div>

		<p class="text-base text-neutral-600 dark:text-neutral-400 leading-relaxed mb-6">
			{description}
		</p>

		<div class="bg-(--card-bg) rounded-(--radius-large) p-4 mb-6">
			<p class="text-sm text-neutral-500 dark:text-neutral-500">
				如果你是我的邻居，但是没有在这里看到自己，可以立刻马上告诉我你的 RSS 订阅地址噢～
			</p>
		</div>

		<div id="pengyou-rss-sources" style="display:none">
			{rss.map((source) => (
				<div
					class="pengyou-rss-source"
					data-name={source.name}
					data-url={source.url}
					data-enabled={source.enabled !== false ? "true" : "false"}
				></div>
			))}
		</div>

		<div data-no-swup>
			<PengyouEditor client:load />
		</div>

		<div class="pengyou-feed" id="pengyou-feed">
			{items.length > 0 ? (
				items.map((item, index) => (
					<article
						key={index}
						class="pengyou-card"
						data-pengyou-item
					>
						<div class="pengyou-card-accent-bar"></div>
						<a
							href={item.link}
							target="_blank"
							rel="noopener nofollow"
							class="pengyou-card-link"
						>
							<div class="pengyou-card-header">
								<div class="pengyou-card-avatar">
									<img
										src={`https://icon.bqb.cool/?url=${item.link.split("//")[1]?.split("/")[0] || ""}`}
										alt={item.author}
										class="pengyou-avatar-img"
									/>
								</div>
								<div class="pengyou-card-meta">
									<span class="pengyou-card-author">{item.author}</span>
									<time class="pengyou-card-date">{formatDate(item.date)}</time>
								</div>
							</div>
							<div class="pengyou-card-body">
								<h2 class="pengyou-card-title">{item.title}</h2>
								<p class="pengyou-card-content">{item.content}</p>
							</div>
						</a>
					</article>
				))
			) : (
				<div class="pengyou-empty">
					<Icon name="material-symbols:sentiment-neutral-outline" class="pengyou-empty-icon" />
					<h3>暂无文章</h3>
					<p>等待朋友们更新动态...</p>
				</div>
			)}
		</div>
	</div>
</MainGridLayout>

<style>
	.pengyou-feed {
		display: flex;
		flex-direction: column;
		gap: 1.5rem;
		padding: 1rem 0 2rem;
	}

	.pengyou-card {
		position: relative;
		background: var(--card-bg);
		border-radius: var(--radius-large);
		padding: 1.25rem 1.25rem 1.25rem 2.25rem;
		border: 2px solid #000;
		overflow: hidden;
		transition:
			box-shadow 0.25s ease,
			transform 0.25s ease,
			border-color 0.25s ease;
	}

	:root.dark .pengyou-card {
		border-color: #3f3f46;
	}

	.pengyou-card-accent-bar {
		position: absolute;
		left: 0;
		top: 0;
		bottom: 0;
		width: 4px;
		background: var(--primary);
		opacity: 0.35;
		border-radius: 0 2px 2px 0;
	}

	.pengyou-card:hover {
		border-color: var(--primary);
		box-shadow: 0 4px 24px rgba(0, 0, 0, 0.1);
		transform: translateY(-2px);
	}

	:root.dark .pengyou-card:hover {
		border-color: #fff;
		box-shadow: 0 4px 24px rgba(255, 255, 255, 0.08);
	}

	.pengyou-card-link {
		display: block;
		text-decoration: none;
		color: inherit;
	}

	.pengyou-card-header {
		display: flex;
		align-items: center;
		gap: 0.625rem;
		margin-bottom: 0.75rem;
	}

	.pengyou-card-avatar {
		flex-shrink: 0;
		width: 2.5rem;
		height: 2.5rem;
		border-radius: 50%;
		overflow: hidden;
		border: 2px solid var(--primary);
		background: var(--btn-regular-bg);
		display: flex;
		align-items: center;
		justify-content: center;
	}

	.pengyou-avatar-img {
		width: 100%;
		height: 100%;
		object-fit: cover;
	}

	.pengyou-card-meta {
		display: flex;
		align-items: center;
		gap: 0.5rem;
		flex-wrap: wrap;
	}

	.pengyou-card-author {
		font-size: 0.9375rem;
		font-weight: 600;
		color: var(--primary);
	}

	.pengyou-card-date {
		font-size: 0.75rem;
		color: var(--content-meta);
	}

	.pengyou-card-body {
		margin-bottom: 0;
	}

	.pengyou-card-title {
		font-size: 1rem;
		font-weight: 600;
		color: var(--text-color);
		margin-bottom: 0.5rem;
		transition: color 0.2s;
	}

	.pengyou-card-link:hover .pengyou-card-title {
		color: var(--primary);
	}

	.pengyou-card-content {
		font-size: 0.875rem;
		color: var(--text-secondary);
		line-height: 1.6;
		display: -webkit-box;
		-webkit-line-clamp: 2;
		-webkit-box-orient: vertical;
		overflow: hidden;
	}

	.pengyou-empty {
		text-align: center;
		padding: 3rem 1rem;
		background: var(--card-bg);
		border: 1px solid var(--border);
		border-radius: 12px;
	}

	.pengyou-empty-icon {
		width: 4rem;
		height: 4rem;
		margin: 0 auto 1rem;
		display: flex;
		align-items: center;
		justify-content: center;
		background: var(--btn-regular-bg);
		border-radius: 50%;
		color: var(--content-meta);
		font-size: 2rem;
	}

	.pengyou-empty h3 {
		font-size: 1rem;
		font-weight: 600;
		color: var(--text-color);
		margin-bottom: 0.375rem;
	}

	.pengyou-empty p {
		font-size: 0.875rem;
		color: var(--content-meta);
		margin: 0;
	}

	@media (max-width: 480px) {
		.pengyou-card {
			padding: 0.875rem;
			border-radius: var(--radius);
		}

		.pengyou-card-header {
			gap: 0.5rem;
		}

		.pengyou-card-avatar {
			width: 2.25rem;
			height: 2.25rem;
		}

		.pengyou-card-author {
			font-size: 0.875rem;
		}

		.pengyou-card-date {
			font-size: 0.6875rem;
		}

		.pengyou-card-title {
			font-size: 0.9375rem;
		}

		.pengyou-card-content {
			font-size: 0.8125rem;
		}
	}
</style>