---
import { Icon } from "astro-icon/components";
import MainGridLayout from "@/layouts/MainGridLayout.astro";
import AlbumEditor from "@/components/edit/AlbumEditor.svelte";
import { getEnabledAlbums, albumPageConfig } from "@/config/albumConfig";

const sortedAlbums = getEnabledAlbums();

const totalPhotos = sortedAlbums.reduce(
	(sum, album) => sum + (album.photos?.length || 0),
	0,
);

const allTags = [
	...new Set(sortedAlbums.flatMap((a) => a.tags || [])),
].sort();

function getAlbumCategory(album: any): string {
	if (album.category) return album.category;
	const photos = album.photos || [];
	if (photos.length > 0) {
		const first = typeof photos[0] === "string" ? photos[0] : photos[0].src;
		if (first && (first.startsWith("http://") || first.startsWith("https://"))) {
			return "network";
		}
	}
	return "local";
}

const localAlbums = sortedAlbums.filter((a) => getAlbumCategory(a) === "local");
const networkAlbums = sortedAlbums.filter((a) => getAlbumCategory(a) === "network");

const title = albumPageConfig.title || "相册";
const description = albumPageConfig.description || "记录生活中的美好瞬间";

function getCover(album: any): string {
	if (album.cover) return album.cover;
	const photos = album.photos || [];
	if (photos.length > 0) {
		const first = photos[0];
		return typeof first === "string" ? first : first.src;
	}
	return "";
}

function formatDate(dateStr: string): string {
	const date = new Date(dateStr);
	return `${date.getFullYear()}.${String(date.getMonth() + 1).padStart(2, "0")}`;
}
---

<MainGridLayout title={title} description={description}>
  <div class="flex w-full rounded-(--radius-large) overflow-hidden relative min-h-32">
    <div class="card-base z-10 px-9 py-6 relative w-full">
      <div class="mb-4 flex justify-between items-start gap-4 flex-wrap">
        <div class="flex-1 min-w-0">
          <div class="flex items-center gap-3 mb-3">
            <div class="h-8 w-8 rounded-lg bg-(--primary) flex items-center justify-center text-white dark:text-black/70">
              <Icon name="material-symbols:photo-album" class="text-[1.5rem]"></Icon>
            </div>
            <div class="text-3xl font-bold text-neutral-900 dark:text-neutral-100">
              {title}
            </div>
          </div>
          <p class="text-base text-neutral-600 dark:text-neutral-400 leading-relaxed mb-4">
            {description}
          </p>
          <div class="flex items-center gap-3 text-sm text-neutral-500 dark:text-neutral-400">
            <span class="flex items-center gap-1">
              <Icon name="material-symbols:photo-album" class="text-sm" />
              {sortedAlbums.length} 个相册
            </span>
            <span class="flex items-center gap-1">
              <Icon name="material-symbols:imagesmode" class="text-sm" />
              {totalPhotos} 张照片
            </span>
          </div>
        </div>
      </div>

      <div data-no-swup>
        <AlbumEditor client:load />
      </div>

      <div id="album-grid">
        <div class="album-category-tabs mb-4">
          <button class="album-category-tab album-category-tab-active" data-category="all">
            全部
            <span class="album-category-count">{sortedAlbums.length}</span>
          </button>
          <button class="album-category-tab" data-category="local">
            本地相册
            <span class="album-category-count">{localAlbums.length}</span>
          </button>
          <button class="album-category-tab" data-category="network">
            网络相册
            <span class="album-category-count">{networkAlbums.length}</span>
          </button>
        </div>

        {sortedAlbums.length > 0 && allTags.length > 0 && (
          <div class="tools-tab-wrapper mb-4">
            <div class="tools-tab-pill" data-album-filter>
              <button
                data-tag="all"
                class="tools-tab-btn tools-tab-btn-active"
              >
                全部
              </button>
              {allTags.map((tag) => (
                <button
                  data-tag={tag}
                  class="tools-tab-btn tools-tab-btn-inactive"
                >
                  {tag}
                </button>
              ))}
            </div>
          </div>
        )}

        {sortedAlbums.length > 0 ? (
          <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6 my-6">
            {sortedAlbums.map((album) => {
              const cover = getCover(album);
              const photoCount = album.photos?.length || 0;
              return (
                <a
                  href={`/album/${album.id}/`}
                  data-tags={album.tags?.join(",") || ""}
                  data-category={getAlbumCategory(album)}
                  class="album-card group"
                >
                  <div class="album-card-imgbox">
                    {cover ? (
                      <img
                        src={cover}
                        alt={album.title}
                        class="album-card-img"
                        loading="lazy"
                        decoding="async"
                      />
                    ) : (
                      <div class="w-full h-full bg-gray-200 dark:bg-gray-700 flex items-center justify-center">
                        <div class="text-gray-400 text-5xl">&#x1f4f7;</div>
                      </div>
                    )}

                    <div class="album-card-badge">
                      {photoCount} 张照片
                    </div>

                    {album.tags && album.tags.length > 0 && (
                      <div class="album-card-tags-overlay">
                        {album.tags.slice(0, 4).map((tag: string) => (
                          <span class="album-card-tag-overlay">{tag}</span>
                        ))}
                      </div>
                    )}
                  </div>

                  <div class="album-card-details">
                    <h3 class="album-card-title">{album.title}</h3>

                    <div class="album-card-meta">
                      {album.date && <span>{formatDate(album.date)}</span>}
                      {album.location && (
                        <span class="album-card-location">
                          <svg class="w-3 h-3" viewBox="0 0 24 24" fill="currentColor"><path d="M12 2C8.13 2 5 5.13 5 9c0 5.25 7 13 7 13s7-7.75 7-13c0-3.87-3.13-7-7-7zm0 9.5a2.5 2.5 0 010-5 2.5 2.5 0 010 5z"/></svg>
                          {album.location}
                        </span>
                      )}
                    </div>
                  </div>
                </a>
              );
            })}
          </div>
        ) : (
          <div class="flex flex-col items-center justify-center py-16 text-neutral-400 dark:text-neutral-500">
            <Icon name="material-symbols:photo-library" class="text-6xl mb-4 opacity-50" />
            <p class="text-lg">暂无相册</p>
          </div>
        )}
      </div>
    </div>
  </div>

  <!-- 筛选交互 -->
  <script is:inline>
    (function() {
      var currentCategory = "all";
      var currentTag = "all";

      function applyFilters() {
        var cards = document.querySelectorAll(".album-card");
        cards.forEach(function(card) {
          var category = card.dataset.category || "local";
          var tags = (card.dataset.tags || "").split(",");
          var categoryMatch = currentCategory === "all" || category === currentCategory;
          var tagMatch = currentTag === "all" || (currentTag && tags.includes(currentTag));
          if (categoryMatch && tagMatch) {
            card.style.display = "";
            card.classList.remove("gallery-card-fade-in");
            void card.offsetHeight;
            card.classList.add("gallery-card-fade-in");
          } else {
            card.style.display = "none";
            card.classList.remove("gallery-card-fade-in");
          }
        });
      }

      // 分类 Tab 切换
      document.addEventListener("click", function(e) {
        var tab = e.target.closest(".album-category-tab");
        if (!tab) return;
        var tabs = tab.parentElement.querySelectorAll(".album-category-tab");
        tabs.forEach(function(t) {
          t.classList.remove("album-category-tab-active");
        });
        tab.classList.add("album-category-tab-active");
        currentCategory = tab.dataset.category || "all";
        applyFilters();
      });

      // 标签筛选
      document.addEventListener("click", function(e) {
        var button = e.target.closest("[data-album-filter] .tools-tab-btn");
        if (!button) return;
        var container = button.closest("[data-album-filter]");
        if (!container) return;

        var selectedTag = button.dataset.tag;
        var filters = container.querySelectorAll(".tools-tab-btn");

        filters.forEach(function(f) {
          f.classList.remove("tools-tab-btn-active");
          f.classList.add("tools-tab-btn-inactive");
        });
        button.classList.remove("tools-tab-btn-inactive");
        button.classList.add("tools-tab-btn-active");

        currentTag = selectedTag || "all";
        applyFilters();
      });
    })();
  </script>

  <style>
    /* 相册分类 Tab */
    .album-category-tabs {
      display: flex;
      gap: 4px;
      margin-bottom: 1rem;
      flex-wrap: wrap;
    }

    .album-category-tab {
      display: inline-flex;
      align-items: center;
      gap: 6px;
      padding: 8px 18px;
      border-radius: 12px;
      font-size: 14px;
      font-weight: 500;
      border: 2px solid #000;
      background: transparent;
      color: var(--btn-content);
      cursor: pointer;
      transition: all 0.2s;
    }

    :root.dark .album-category-tab {
      border-color: #52525b;
    }

    .album-category-tab:hover {
      background: rgba(0, 0, 0, 0.05);
    }

    :root.dark .album-category-tab:hover {
      background: rgba(255, 255, 255, 0.1);
    }

    .album-category-tab-active {
      background: #000;
      color: #fff;
      border-color: #000;
    }

    :root.dark .album-category-tab-active {
      background: #fff;
      color: #000;
      border-color: #fff;
    }

    .album-category-count {
      padding: 1px 7px;
      border-radius: 9999px;
      font-size: 11px;
      font-weight: 600;
      background: rgba(0, 0, 0, 0.08);
      color: inherit;
    }

    .album-category-tab-active .album-category-count {
      background: rgba(255, 255, 255, 0.2);
    }

    :root.dark .album-category-tab-active .album-category-count {
      background: rgba(0, 0, 0, 0.15);
    }

    /* 筛选标签样式 - 黑色胶囊 */
    .tools-tab-wrapper {
      display: flex;
      margin-bottom: 1rem;
    }

    .tools-tab-pill {
      display: inline-flex;
      background: transparent;
      border: 1.5px solid #000;
      border-radius: 9999px;
      padding: 3px;
      gap: 2px;
      position: relative;
    }

    :root.dark .tools-tab-pill {
      border-color: #52525b;
    }

    .tools-tab-btn {
      padding: 5px 16px;
      border-radius: 9999px;
      font-size: 13px;
      font-weight: 500;
      border: none;
      cursor: pointer;
      transition: all 0.2s;
      background: transparent;
      color: var(--btn-content);
      position: relative;
      z-index: 1;
    }

    .tools-tab-btn-active {
      background: #000;
      color: #fff;
    }

    :root.dark .tools-tab-btn-active {
      background: #fff;
      color: #000;
    }

    .tools-tab-btn-inactive {
      background: transparent;
      color: var(--btn-content);
    }

    .tools-tab-btn-inactive:hover {
      background: rgba(0, 0, 0, 0.06);
    }

    :root.dark .tools-tab-btn-inactive:hover {
      background: rgba(255, 255, 255, 0.1);
    }

    /* 淡入动画 */
    .gallery-card-fade-in {
      animation: galleryFadeInUp 0.35s ease-out both;
    }

    @keyframes galleryFadeInUp {
      from {
        opacity: 0;
        transform: translateY(10px);
      }
      to {
        opacity: 1;
        transform: translateY(0);
      }
    }

    /* 相册卡片样式 */
    .album-card {
      position: relative;
      display: block;
      overflow: visible;
      width: 100%;
      height: 254px;
      background: #1f1f1f;
      border-radius: 4px;
      border: 1px solid rgba(0, 0, 0, 0.3);
      box-shadow: 0 2px 8px rgba(0, 0, 0, .15);
      transition: 0.3s;
      text-decoration: none;
    }

    :root.dark .album-card {
      background: #f5f5f5;
      border-color: rgba(255, 255, 255, 0.2);
      box-shadow: 0 2px 8px rgba(0, 0, 0, .3);
    }

    .album-card::before,
    .album-card::after {
      content: "";
      position: absolute;
      top: 0;
      left: 0;
      width: 100%;
      height: 100%;
      border-radius: 4px;
      background: #1f1f1f;
      transition: 0.5s;
      z-index: -1;
      border: 1px solid rgba(0, 0, 0, 0.2);
    }

    :root.dark .album-card::before,
    :root.dark .album-card::after {
      background: #f5f5f5;
      border-color: rgba(255, 255, 255, 0.15);
    }

    .album-card:hover::before {
      transform: rotate(1.5deg) translateY(1px);
    }

    .album-card:hover::after {
      transform: rotate(0.8deg) translateY(0.5px);
      box-shadow: 0 2px 12px rgba(0, 0, 0, .15);
    }

    :root.dark .album-card:hover::after {
      box-shadow: 0 2px 12px rgba(0, 0, 0, .3);
    }

    .album-card-imgbox {
      position: absolute;
      top: 6px;
      left: 6px;
      bottom: 6px;
      right: 6px;
      background: #222;
      transition: bottom 0.5s;
      z-index: 1;
      overflow: hidden;
      border-radius: 2px;
    }

    .album-card:hover .album-card-imgbox {
      bottom: 80px;
    }

    .album-card-img {
      width: 100%;
      height: 100%;
      object-fit: cover;
      pointer-events: none;
      transition: transform 0.5s;
    }

    .album-card:hover .album-card-img {
      transform: scale(1.05);
    }

    .album-card-badge {
      position: absolute;
      top: 8px;
      right: 8px;
      padding: 4px 10px;
      border-radius: 9999px;
      font-size: 0.75rem;
      font-weight: 500;
      color: #fff;
      background: rgba(0, 0, 0, 0.5);
      backdrop-filter: blur(4px);
      z-index: 2;
      transition: opacity 0.3s;
    }

    .album-card:hover .album-card-badge {
      opacity: 0;
    }

    .album-card-tags-overlay {
      position: absolute;
      bottom: 8px;
      left: 8px;
      display: flex;
      flex-wrap: wrap;
      gap: 4px;
      z-index: 2;
      transition: opacity 0.3s;
    }

    .album-card:hover .album-card-tags-overlay {
      opacity: 0;
    }

    .album-card-tag-overlay {
      font-size: 0.65rem;
      padding: 2px 8px;
      border-radius: 4px;
      background: rgba(0, 0, 0, 0.5);
      backdrop-filter: blur(4px);
      color: #fff;
      white-space: nowrap;
    }

    .album-card-details {
      position: absolute;
      left: -10px;
      right: 0;
      bottom: 5px;
      height: 60px;
      text-align: center;
      text-transform: uppercase;
      z-index: 0;
    }

    .album-card-title {
      font-weight: 600;
      font-size: 1.25rem;
      color: #fff;
      line-height: 1.2;
      margin: 0;
    }

    :root.dark .album-card-title {
      color: #444;
    }

    .album-card-meta {
      display: flex;
      align-items: center;
      justify-content: center;
      gap: 0.75rem;
      font-size: 0.875rem;
      color: #ccc;
      margin-top: 4px;
      overflow: hidden;
      white-space: nowrap;
      text-overflow: ellipsis;
      padding: 0 10px;
    }

    :root.dark .album-card-meta {
      color: #555;
    }

    .album-card-meta > span {
      overflow: hidden;
      white-space: nowrap;
      text-overflow: ellipsis;
      max-width: 100%;
    }

    .album-card-location {
      display: inline-flex;
      align-items: center;
      gap: 0.125rem;
      overflow: hidden;
      white-space: nowrap;
      text-overflow: ellipsis;
      max-width: 100%;
    }
  </style>
</MainGridLayout>
