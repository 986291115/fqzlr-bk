---
import MainGridLayout from "@/layouts/MainGridLayout.astro";
import { getCollection } from "astro:content";
import { Icon } from "astro-icon/components";
import { url } from "@/utils/url-utils";

// 获取所有导航数据
const allEntries = await getCollection("daohang");

// 按分类分组
const categoryMap = new Map<string, typeof allEntries>();
const allCategories: string[] = [];
const featuredSites: typeof allEntries = [];

allEntries.forEach((entry) => {
	const cat = entry.data.category || "未分类";
	if (!categoryMap.has(cat)) {
		categoryMap.set(cat, []);
		allCategories.push(cat);
	}
	categoryMap.get(cat)!.push(entry);

	if (entry.data.featured) {
		featuredSites.push(entry);
	}
});

// 排序
const sortedCategories = allCategories.sort((a, b) => {
	// 我的网站排最前
	if (a === "我的网站") return -1;
	if (b === "我的网站") return 1;
	return 0;
});

const categoryOrder: Record<string, number> = {
	"我的网站": 0,
	"常用网站": 1,
	"资源网站": 2,
	"工具网站": 3,
	"大佬博客": 4,
	"学习网站": 5,
	"文档": 6,
	"其他网站": 7,
};

const sortedData = new Map(
	[...categoryMap.entries()].sort(([a], [b]) => {
		const orderA = categoryOrder[a] ?? 99;
		const orderB = categoryOrder[b] ?? 99;
		return orderA - orderB;
	}).map(([cat, items]) => [
		cat,
		[...items].sort((a, b) => {
			const orderA = a.data.order ?? 99;
			const orderB = b.data.order ?? 99;
			return orderA - orderB;
		}),
	])
);

// 分类颜色
const categoryColors: Record<string, { color: string; bg: string }> = {
	"我的网站": { color: "#3b82f6", bg: "rgba(59, 130, 246, 0.1)" },
	"常用网站": { color: "#f97316", bg: "rgba(249, 115, 22, 0.1)" },
	"资源网站": { color: "#ec4899", bg: "rgba(236, 72, 153, 0.1)" },
	"工具网站": { color: "#10b981", bg: "rgba(16, 185, 129, 0.1)" },
	"大佬博客": { color: "#8b5cf6", bg: "rgba(139, 92, 246, 0.1)" },
	"学习网站": { color: "#06b6d4", bg: "rgba(6, 182, 212, 0.1)" },
	"文档": { color: "#84cc16", bg: "rgba(132, 204, 22, 0.1)" },
	"其他网站": { color: "#6b7280", bg: "rgba(107, 114, 128, 0.1)" },
};

const getCategoryColor = (cat: string) => {
	return categoryColors[cat] || { color: "#6b7280", bg: "rgba(107, 114, 128, 0.1)" };
};

// 分类图标
const categoryIcons: Record<string, string> = {
	"我的网站": "material-symbols:person",
	"常用网站": "material-symbols:star",
	"资源网站": "material-symbols:folder",
	"工具网站": "material-symbols:handyman",
	"大佬博客": "material-symbols:menu-book",
	"学习网站": "material-symbols:menu-book",
	"文档": "material-symbols:description",
	"其他网站": "material-symbols:link",
};

const getCategoryIcon = (cat: string) => {
	return categoryIcons[cat] || "material-symbols:link";
};
---

<MainGridLayout title="网站导航" description="收录个人网站、常用工具和收藏网站">
	<div class="daohang-container">
		<!-- 侧边装饰光晕 -->
		<div class="sidebar-glow left"></div>
		<div class="sidebar-glow right"></div>

		<!-- 精选网站 -->
		{featuredSites.length > 0 && (
			<div class="featured-section">
				<div class="section-header">
					<div class="section-title-wrap">
						<Icon name="material-symbols:star" class="section-icon" />
						<h2 class="section-title">精选网站</h2>
					</div>
				</div>
				<div class="featured-grid">
					{featuredSites.map((site) => (
						<a
							href={site.data.url}
							target="_blank"
							rel="noopener noreferrer"
							class="featured-card"
						>
							<div
								class="featured-card-glow"
								style={`background: ${site.data.color || '#3b82f6'};`}
							></div>
							<div class="featured-card-inner">
								<div class="featured-icon-wrap" style={`background: ${site.data.color || '#3b82f6'}20;`}>
									{site.data.icon ? (
										<Icon name={site.data.icon} class="featured-icon" style={`color: ${site.data.color || '#3b82f6'};`} />
									) : (
										<Icon name="material-symbols:language" class="featured-icon" style={`color: ${site.data.color || '#3b82f6'};`} />
									)}
								</div>
								<div class="featured-info">
									<h3 class="featured-name">{site.data.name}</h3>
									<p class="featured-desc">{site.data.description}</p>
								</div>
								<div class="featured-arrow">
									<Icon name="material-symbols:arrow-outward-rounded" class="arrow-icon" />
								</div>
							</div>
						</a>
					))}
				</div>
			</div>
		)}

		<!-- 分类导航 -->
		<div class="category-nav">
			<a href="#all" class="category-tab active" data-category="all">
				<span class="tab-dot"></span>
				全部
			</a>
			{sortedCategories.map((cat) => (
				<a href={`#${cat}`} class="category-tab" data-category={cat}>
					<span
						class="tab-dot"
						style={`background: ${getCategoryColor(cat).color};`}
					></span>
					{cat}
				</a>
			))}
		</div>

		<!-- 分类列表 -->
		<div class="categories-container" id="all">
			{sortedCategories.map((cat) => {
				const items = sortedData.get(cat)!;
				const catColor = getCategoryColor(cat);
				return (
					<section class="category-section" id={cat} data-category={cat}>
						<div class="category-header">
							<div class="category-title-wrap">
								<div class="category-icon-wrap" style={`background: ${catColor.bg};`}>
									<Icon name={getCategoryIcon(cat)} class="category-icon" style={`color: ${catColor.color};`} />
								</div>
								<div>
									<h2 class="category-title">{cat}</h2>
									<span class="category-count">{items.length} 个网站</span>
								</div>
							</div>
							<div class="category-line" style={`background: linear-gradient(to right, ${catColor.color}, transparent);`}></div>
						</div>

						<div class="sites-grid">
							{items.map((site) => (
								<a
									href={site.data.url}
									target="_blank"
									rel="noopener noreferrer"
									class="site-card"
									data-category={cat}
								>
									<div class="site-card-accent" style={`background: ${site.data.color || catColor.color};`}></div>
									<div class="site-card-inner">
										<div class="site-icon-wrap" style={`background: ${(site.data.color || catColor.color)}15;`}>
											{site.data.icon ? (
												<Icon name={site.data.icon} class="site-icon" style={`color: ${site.data.color || catColor.color};`} />
											) : site.data.image ? (
												<img src={site.data.image} alt={site.data.name} class="site-image" />
											) : (
												<Icon name="material-symbols:language" class="site-icon" style={`color: ${site.data.color || catColor.color};`} />
											)}
										</div>
										<div class="site-content">
											<div class="site-name">{site.data.name}</div>
											<div class="site-desc">{site.data.description}</div>
											{site.data.tags && site.data.tags.length > 0 && (
												<div class="site-tags">
													{site.data.tags.slice(0, 2).map((tag) => (
														<span class="site-tag">{tag}</span>
													))}
												</div>
											)}
										</div>
										<div class="site-arrow">
											<Icon name="material-symbols:arrow-outward-rounded" class="site-arrow-icon" />
										</div>
									</div>
								</a>
							))}
						</div>
					</section>
				);
			})}
		</div>

		<!-- 底部装饰 -->
		<div class="footer-decoration">
			<span class="footer-text">点击即可跳转到对应网站</span>
		</div>
	</div>
</MainGridLayout>

<script>
	// 分类切换逻辑
	function initCategoryNav() {
		const tabs = document.querySelectorAll('.category-tab');
		const sections = document.querySelectorAll('.category-section');

		tabs.forEach((tab) => {
			tab.addEventListener('click', (e) => {
				const target = e.currentTarget as HTMLElement;
				const category = target.dataset.category;

				// 更新 tab 状态
				tabs.forEach((t) => t.classList.remove('active'));
				target.classList.add('active');

				// 显示/隐藏分类
				if (category === 'all') {
					sections.forEach((s) => {
						(s as HTMLElement).style.display = '';
					});
				} else {
					sections.forEach((s) => {
						const section = s as HTMLElement;
						if (section.dataset.category === category) {
							section.style.display = '';
						} else {
							section.style.display = 'none';
						}
					});
				}
			});
		});

		// 滚动时高亮对应 tab
		const observer = new IntersectionObserver(
			(entries) => {
				entries.forEach((entry) => {
					if (entry.isIntersecting) {
						const id = entry.target.id;
						tabs.forEach((tab) => {
							const t = tab as HTMLElement;
							if (t.dataset.category === id) {
								t.classList.add('active');
							} else if (id === 'all') {
								// 不处理
							} else {
								t.classList.remove('active');
							}
						});
					}
				});
			},
			{ rootMargin: '-20% 0px -60% 0px' }
		);

		sections.forEach((s) => observer.observe(s));
	}

	if (document.readyState === 'loading') {
		document.addEventListener('DOMContentLoaded', () => {
			initCategoryNav();
		});
	} else {
		initCategoryNav();
	}
</script>

<style>
	.daohang-container {
		position: relative;
		margin: 0 auto;
		padding: 0 16px 40px;
	}

	/* 侧边装饰光晕 */
	.sidebar-glow {
		position: fixed;
		top: 50%;
		transform: translateY(-50%);
		width: 400px;
		height: 400px;
		border-radius: 50%;
		pointer-events: none;
		z-index: 0;
	}

	.sidebar-glow.left {
		left: -200px;
		background: radial-gradient(circle, #3b82f6 0%, transparent 70%);
		opacity: 0.1;
	}

	.sidebar-glow.right {
		right: -200px;
		background: radial-gradient(circle, #ec4899 0%, transparent 70%);
		opacity: 0.07;
	}

	/* 顶部标题卡片 */
	.header-card {
		position: relative;
		background: var(--card-bg);
		border: 1px solid var(--border);
		border-radius: 24px;
		overflow: hidden;
		margin-bottom: 20px;
		z-index: 1;
	}

	.header-bg-deco {
		position: absolute;
		top: -60px;
		right: -40px;
		width: 200px;
		height: 200px;
		border-radius: 50%;
		background: linear-gradient(135deg, var(--primary) 0%, transparent 60%);
		opacity: 0.08;
		pointer-events: none;
	}

	.header-content {
		position: relative;
		padding: 28px 32px;
		display: flex;
		align-items: center;
		gap: 20px;
	}

	.header-icon-wrap {
		width: 60px;
		height: 60px;
		display: flex;
		align-items: center;
		justify-content: center;
		background: linear-gradient(135deg, var(--primary) 0%, color-mix(in srgb, var(--primary) 60%, #000) 100%);
		border-radius: 18px;
		flex-shrink: 0;
		box-shadow: 0 8px 24px var(--primary)/20;
	}

	.header-icon {
		font-size: 30px;
		color: white;
	}

	.header-text {
		flex: 1;
	}

	.header-title {
		font-size: 24px;
		font-weight: 800;
		color: var(--text-color);
