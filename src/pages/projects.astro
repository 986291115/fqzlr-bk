	.footer-decoration {
		display: flex;
		align-items: center;
		justify-content: center;
		padding: 24px 0 8px;
	}

	.footer-text {
		font-size: 12px;
		color: var(--content-meta);
		opacity: 0.6;
	}

	/* 响应式 */
	@media (max-width: 640px) {
		.header-content {
			flex-direction: column;
			text-align: center;
			padding: 20px;
		}

		.header-stats {
			justify-content: center;
		}

		.header-icon-wrap {
			width: 52px;
			height: 52px;
		}

		.header-icon {
			font-size: 26px;
		}

		.header-title {
			font-size: 20px;
		}

		.featured-grid {
			grid-template-columns: repeat(2, 1fr);
		}

		.category-nav {
			padding: 12px;
			gap: 6px;
		}

		.category-tab {
			padding: 6px 10px;
			font-size: 12px;
