	.featured-card-inner {
		position: relative;
		padding: 18px 16px;
		display: flex;
		flex-direction: column;
		align-items: center;
		text-align: center;
		width: 100%;
	}

	.featured-icon-wrap {
		width: 48px;
		height: 48px;
		display: flex;
		align-items: center;
		justify-content: center;
		border-radius: 14px;
		margin-bottom: 12px;
	}

	.featured-icon {
		font-size: 24px;
	}

	.featured-info {
