		color: var(--primary);
	}

	.featured-desc {
		font-size: 11px;
		color: var(--content-meta);
		line-height: 1.4;
		display: -webkit-box;
		-webkit-line-clamp: 2;
		-webkit-box-orient: vertical;
		overflow: hidden;
	}

	.featured-arrow {
		position: absolute;
		top: 12px;
		right: 12px;
		opacity: 0;
		transition: all 0.3s ease;
	}

	.featured-card:hover .featured-arrow {
		opacity: 1;
	}

	.arrow-icon {
		font-size: 16px;
		color: var(--primary);
	}

