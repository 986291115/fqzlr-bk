	.site-arrow {
		flex-shrink: 0;
		opacity: 0;
		transition: all 0.3s ease;
		transform: translateX(-5px);
	}

	.site-card:hover .site-arrow {
		opacity: 1;
		transform: translateX(0);
	}

	.site-arrow-icon {
		font-size: 16px;
		color: var(--primary);
	}

