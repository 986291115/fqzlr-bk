	.category-section {
		background: var(--card-bg);
		border: 1px solid var(--border);
		border-radius: 20px;
		padding: 24px;
		z-index: 1;
		position: relative;
	}

	.category-header {
		margin-bottom: 20px;
	}

	.category-title-wrap {
		display: flex;
		align-items: center;
		gap: 14px;
		margin-bottom: 12px;
	}

	.category-icon-wrap {
		width: 40px;
		height: 40px;
		display: flex;
		align-items: center;
		justify-content: center;
		border-radius: 12px;
		flex-shrink: 0;
	}

	.category-icon {
		font-size: 20px;
	}

	.category-title {
		font-size: 16px;
		font-weight: 700;
		color: var(--text-color);
	}

	.category-count {
		font-size: 12px;
		color: var(--content-meta);
	}

	.category-line {
		height: 2px;
		border-radius: 1px;
		opacity: 0.4;
	}

	/* 网站网格 */
	.sites-grid {
		display: grid;
		grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
		gap: 12px;
	}

	.site-card {
		position: relative;
		display: flex;
		background: var(--bg-color);
		border: 1px solid var(--border);
		border-radius: 14px;
		overflow: hidden;
		text-decoration: none;
