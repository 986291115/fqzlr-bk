---
import { Icon } from "astro-icon/components";
import { siteConfig, sponsorConfig } from "@/config";
import I18nKey from "@/i18n/i18nKey";
import { i18n } from "@/i18n/translation";
import MainGridLayout from "@/layouts/MainGridLayout.astro";
import { url } from "@/utils/url-utils";
import SponsorEditor from "@/components/edit/SponsorEditor.svelte";

// 检查页面是否启用
if (!siteConfig.pages.sponsor) {
	return Astro.redirect("/404/");
}

const title = sponsorConfig.title || i18n(I18nKey.sponsorTitle);
const description =
	sponsorConfig.description || i18n(I18nKey.sponsorDescription);
const enabledMethods = sponsorConfig.methods.filter((method) => method.enabled);
const sponsors = sponsorConfig.sponsors || [];
const showSponsorsList = sponsorConfig.showSponsorsList !== false;
---

<MainGridLayout title={title} description={description}>
  <div class="flex w-full rounded-(--radius-large) overflow-hidden relative min-h-32">
    <div class="card-base z-10 px-9 py-6 relative w-full">
      <!-- 页面标题和描述 -->
      <div class="mb-8">
        <div class="flex items-center gap-3 mb-3">
            <div class="h-8 w-8 rounded-lg bg-(--primary) flex items-center justify-center text-white dark:text-black/70">
                <Icon name="material-symbols:favorite" class="text-[1.5rem]"></Icon>
            </div>
          <h1 class="text-3xl font-bold text-neutral-900 dark:text-neutral-100">
            {title}
          </h1>
        </div>
        {description && (
          <p class="text-base text-neutral-600 dark:text-neutral-400 leading-relaxed mb-4">
            {description}
          </p>
        )}

        <!-- 赞助编辑器 -->
        <div data-no-swup>
          <SponsorEditor client:only />
        </div>

        {sponsorConfig.usage && (
          <div class="mb-8 p-4 rounded-lg bg-(--primary)/8 dark:bg-(--btn-regular-bg) border border-(--primary)/30 dark:border-none backdrop-blur-xs shadow-xs usage-info-box">
            <div class="flex items-start gap-2">
              <Icon name="material-symbols:info-outline" class="text-(--primary) text-lg shrink-0 mt-0.5" />
              <p class="text-sm text-neutral-700 dark:text-neutral-200 leading-relaxed">
                <span class="font-semibold text-(--primary)"></span>
                {sponsorConfig.usage}
              </p>
            </div>
          </div>
        )}
      </div>

      <!-- 扫码赞助卡片 -->
      <div class="mb-10">
        <div class="sponsor-card">
          <div class="sponsor-card__header">
            <h3 class="sponsor-card__title">扫码赞助</h3>
            <p class="sponsor-card__subtitle">选择你喜欢的支付方式</p>
          </div>

          <div class="sponsor-tabs">
            {enabledMethods.map((method, idx) => (
              <button
                class="sponsor-tab"
                class:sponsor-tab--active={idx === 0}
                data-sponsor-tab={idx}
              >
                {method.icon && <Icon name={method.icon} class="text-sm" />}
                {method.name}
              </button>
            ))}
          </div>

          {enabledMethods.map((method, idx) => (
            <div
              class="sponsor-tab-panel"
              class:sponsor-tab-panel--active={idx === 0}
              data-sponsor-panel={idx}
            >
              {method.link ? (
                <div class="sponsor-link-card">
                  <h2 class="sponsor-link-card__title">{method.name}</h2>
                  <p class="sponsor-link-card__desc">
                    {method.description || `通过${method.name}进行打赏`}
                  </p>
                  <a
                    href={method.link}
                    target="_blank"
                    rel="noopener noreferrer"
                    class="sponsor-link-card__btn"
                  >
                    前往打赏
                    <Icon name="material-symbols:open-in-new" class="text-lg" />
                  </a>
                </div>
              ) : method.qrCode ? (
                <div class="sponsor-qr-section">
                  <div class="sponsor-qr-img-wrap">
                    <img
                      src={url(method.qrCode)}
                      alt={`${method.name} 扫码赞助`}
                      class="sponsor-qr-img"
                      loading="lazy"
                    />
                  </div>
                  {method.description && (
                    <p class="sponsor-qr-desc">{method.description}</p>
                  )}
                </div>
              ) : (
                <div class="sponsor-empty">
                  <p class="text-neutral-400">暂无赞助方式</p>
                </div>
              )}
            </div>
          ))}
        </div>
      </div>

      <!-- 赞助名单 -->
      {showSponsorsList && (
        <div>
          <h2 class="sponsor-list-title">赞助名单</h2>
          {sponsors.length > 0 ? (
            <div class="sponsor-cards">
              {sponsors.map((sponsor) => (
                <div class="sponsor-card-item">
                  <div class="sponsor-card-item__avatar">
                    {sponsor.avatar ? (
                      <img
                        src={sponsor.avatar}
                        alt={sponsor.name}
                        loading="lazy"
                      />
                    ) : (
                      <span>{sponsor.name.charAt(0)}</span>
                    )}
                  </div>
                  <div class="sponsor-card-item__info">
                    <div class="sponsor-card-item__name">{sponsor.name}</div>
                    {sponsor.date && (
                      <div class="sponsor-card-item__date">
                        {new Date(sponsor.date).toLocaleDateString()}
                      </div>
                    )}
                  </div>
                  {sponsor.amount && (
                    <div class="sponsor-card-item__amount">{sponsor.amount}</div>
                  )}
                </div>
              ))}
            </div>
          ) : (
            <div class="text-center py-8 text-neutral-500">
              <p>暂无赞助记录</p>
            </div>
          )}
        </div>
      )}
    </div>
  </div>
</MainGridLayout>

<style>
  /* 透明模式下使用半透明背景 */
  :global(body.wallpaper-transparent .usage-info-box) {
    background-color: rgba(var(--primary-rgb, 70, 130, 180), 0.15) !important;
  }
  
  :global(:root.dark body.wallpaper-transparent .usage-info-box) {
    background-color: oklch(from var(--primary) l c h / 0.15) !important;
  }

  /* 扫码赞助大卡片 */
  .sponsor-card {
    border: 2px solid #1f2937;
    border-radius: 16px;
    padding: 32px;
    background: var(--card-bg, #fff);
  }
  :root.dark .sponsor-card {
    background: #18181b;
    border-color: #3f3f46;
  }

  .sponsor-card__header {
    margin-bottom: 20px;
  }

  .sponsor-card__title {
    font-size: 20px;
    font-weight: 700;
    color: #1f2937;
    margin: 0 0 6px 0;
  }
  :root.dark .sponsor-card__title {
    color: #f4f4f5;
  }

  .sponsor-card__subtitle {
    font-size: 15px;
    color: #6b7280;
    margin: 0;
  }
  :root.dark .sponsor-card__subtitle {
    color: #a1a1aa;
  }

  /* 胶囊 Tab */
  .sponsor-tabs {
    display: inline-flex;
    border: 2px solid #1f2937;
    border-radius: 9999px;
    padding: 4px;
    margin-bottom: 24px;
    background: #fff;
  }
  :root.dark .sponsor-tabs {
    background: #27272a;
    border-color: #52525b;
  }

  .sponsor-tab {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    padding: 8px 20px;
    font-size: 15px;
    font-weight: 500;
    border: none;
    border-radius: 9999px;
    background: transparent;
    color: #1f2937;
    cursor: pointer;
    transition: all 0.2s ease;
    font-family: inherit;
  }
  :root.dark .sponsor-tab {
    color: #d4d4d8;
  }

  .sponsor-tab--active {
    background: #000;
    color: #fff;
  }
  :root.dark .sponsor-tab--active {
    background: #fff;
    color: #000;
  }

  .sponsor-tab:hover:not(.sponsor-tab--active) {
    background: rgba(0, 0, 0, 0.05);
  }
  :root.dark .sponsor-tab:hover:not(.sponsor-tab--active) {
    background: rgba(255, 255, 255, 0.05);
  }

  /* Tab Panel */
  .sponsor-tab-panel {
    display: none;
  }
  .sponsor-tab-panel--active {
    display: block;
    animation: fadeIn 0.3s ease;
  }

  @keyframes fadeIn {
    from { opacity: 0; transform: translateY(4px); }
    to { opacity: 1; transform: translateY(0); }
  }

  /* 爱发电/链接卡片 */
  .sponsor-link-card {
    text-align: center;
    padding: 40px 20px;
  }

  .sponsor-link-card__title {
    font-size: 72px;
    font-weight: 900;
    color: #1f2937;
    margin: 0 0 8px 0;
    letter-spacing: -2px;
  }
  :root.dark .sponsor-link-card__title {
    color: #f4f4f5;
  }

  .sponsor-link-card__desc {
    font-size: 22px;
    color: #6b7280;
    margin: 0 0 32px 0;
    font-weight: 500;
  }
  :root.dark .sponsor-link-card__desc {
    color: #a1a1aa;
  }

  .sponsor-link-card__btn {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    padding: 16px 48px;
    font-size: 24px;
    font-weight: 600;
    color: #1f2937;
    background: #fff;
    border: 2px solid #1f2937;
    border-radius: 16px;
    text-decoration: none;
    transition: all 0.2s ease;
  }
  :root.dark .sponsor-link-card__btn {
    background: #27272a;
    border-color: #52525b;
    color: #f4f4f5;
  }

  .sponsor-link-card__btn:hover {
    background: #f9fafb;
    transform: translateY(-2px);
    box-shadow: 0 8px 20px rgba(0, 0, 0, 0.1);
  }
  :root.dark .sponsor-link-card__btn:hover {
    background: #3f3f46;
  }

  /* 二维码样式 */
  .sponsor-qr-section {
    text-align: center;
    padding: 20px 0;
  }

  .sponsor-qr-img-wrap {
    width: 240px;
    height: 240px;
    margin: 0 auto 16px;
    padding: 16px;
    background: #fff;
    border: 2px solid #e5e7eb;
    border-radius: 12px;
  }
  :root.dark .sponsor-qr-img-wrap {
    background: #fff;
    border-color: #3f3f46;
  }

  .sponsor-qr-img {
    width: 100%;
    height: 100%;
    object-fit: contain;
  }

  .sponsor-qr-desc {
    font-size: 14px;
    color: #6b7280;
    margin: 0;
  }
  :root.dark .sponsor-qr-desc {
    color: #a1a1aa;
  }

  .sponsor-empty {
    text-align: center;
    padding: 40px 0;
  }

  /* 赞助名单 */
  .sponsor-list-title {
    font-size: 24px;
    font-weight: 700;
    color: #1f2937;
    margin: 0 0 20px 0;
  }
  :root.dark .sponsor-list-title {
    color: #f4f4f5;
  }

  .sponsor-cards {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 16px;
  }

  .sponsor-card-item {
    display: flex;
    align-items: center;
    gap: 12px;
    padding: 14px 16px;
    border: 2px solid #1f2937;
    border-radius: 14px;
    background: var(--card-bg, #fff);
  }
  :root.dark .sponsor-card-item {
    background: #18181b;
    border-color: #3f3f46;
  }

  .sponsor-card-item__avatar {
    width: 48px;
    height: 48px;
    border-radius: 50%;
    overflow: hidden;
    flex-shrink: 0;
    background: #e5e7eb;
    display: flex;
    align-items: center;
    justify-content: center;
    font-weight: 700;
    font-size: 18px;
    color: #6b7280;
  }
  :root.dark .sponsor-card-item__avatar {
    background: #3f3f46;
    color: #a1a1aa;
  }

  .sponsor-card-item__avatar img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .sponsor-card-item__info {
    flex: 1;
    min-width: 0;
  }

  .sponsor-card-item__name {
    font-size: 16px;
    font-weight: 700;
    color: #1f2937;
    line-height: 1.3;
  }
  :root.dark .sponsor-card-item__name {
    color: #f4f4f5;
  }

  .sponsor-card-item__date {
    font-size: 13px;
    color: #9ca3af;
    margin-top: 2px;
  }
  :root.dark .sponsor-card-item__date {
    color: #71717a;
  }

  .sponsor-card-item__amount {
    font-size: 18px;
    font-weight: 700;
    color: #1f2937;
    flex-shrink: 0;
  }
  :root.dark .sponsor-card-item__amount {
    color: #f4f4f5;
  }

  @media (max-width: 768px) {
    .sponsor-card {
      padding: 20px;
    }
    .sponsor-link-card__title {
      font-size: 48px;
    }
    .sponsor-link-card__desc {
      font-size: 18px;
    }
    .sponsor-link-card__btn {
      padding: 12px 32px;
      font-size: 18px;
    }
    .sponsor-cards {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (max-width: 480px) {
    .sponsor-tabs {
      width: 100%;
    }
    .sponsor-tab {
      flex: 1;
      justify-content: center;
      padding: 8px 12px;
      font-size: 13px;
    }
    .sponsor-link-card__title {
      font-size: 36px;
    }
    .sponsor-link-card__desc {
      font-size: 16px;
    }
    .sponsor-link-card__btn {
      padding: 10px 24px;
      font-size: 16px;
    }
    .sponsor-cards {
      grid-template-columns: 1fr;
    }
  }
</style>

<!-- Tab 切换交互 -->
<script is:inline>
  (function() {
    document.addEventListener("click", function(e) {
      var tab = e.target.closest(".sponsor-tab");
      if (!tab) return;
      var card = tab.closest(".sponsor-card");
      if (!card) return;

      var idx = tab.dataset.sponsorTab;
      var tabs = card.querySelectorAll(".sponsor-tab");
      var panels = card.querySelectorAll(".sponsor-tab-panel");

      tabs.forEach(function(t) {
        if (t.dataset.sponsorTab === idx) {
          t.classList.add("sponsor-tab--active");
        } else {
          t.classList.remove("sponsor-tab--active");
        }
      });

      panels.forEach(function(p) {
        if (p.dataset.sponsorPanel === idx) {
          p.classList.add("sponsor-tab-panel--active");
        } else {
          p.classList.remove("sponsor-tab-panel--active");
        }
      });
    });
  })();
</script>

