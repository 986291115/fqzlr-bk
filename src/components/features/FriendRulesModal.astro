---
import { Icon } from "astro-icon/components";
import { friendsPageConfig } from "@/config";

interface Props {
	applyLink?: string | boolean;
}

const { applyLink = friendsPageConfig.applyLink } = Astro.props;

const siteInfo = (friendsPageConfig as any).siteInfo;
const notes = (friendsPageConfig as any).notes;
const githubIssue = (friendsPageConfig as any).githubIssue;

function buildIssueUrl(): string {
	if (!githubIssue?.repo) return "";
	const repo = githubIssue.repo;
	const labels = githubIssue.labels || [];
	const title = encodeURIComponent("[友链申请] 站点名称");
	const body = encodeURIComponent(`## 站点信息

- **站点名称**：
- **站点描述**：
- **站点链接**：
- **头像链接**：

## 补充说明

<!-- 在这里补充其他说明 -->
`);
	const labelParam = labels.length > 0 ? `&labels=${labels.map(encodeURIComponent).join(",")}` : "";
	return `https://github.com/${repo}/issues/new?title=${title}${labelParam}&body=${body}`;
}

const issueUrl = buildIssueUrl();
---

<dialog id="friend-rules-modal" class="fr-modal">
  <div class="fr-overlay" data-close-modal></div>
  <div class="fr-panel">
    <div class="fr-header">
      <h2 class="fr-title">友链申请指南</h2>
      <button class="fr-close" data-close-modal aria-label="关闭">
        <Icon name="material-symbols:close-rounded" class="text-xl" />
      </button>
    </div>

    <div class="fr-body">
      {siteInfo && (
        <section class="fr-section">
          <div class="fr-section-head">
            <div class="fr-section-icon">
              <Icon name="material-symbols:info-outline-rounded" />
            </div>
            <h3>本站信息</h3>
          </div>
          <div class="fr-info-grid">
            {[
              { label: "站点名称", value: siteInfo.name },
              { label: "站点描述", value: siteInfo.desc },
              { label: "站点链接", value: siteInfo.url },
              { label: "头像链接", value: siteInfo.avatar },
            ].map((item) => (
              <div class="fr-info-row">
                <div class="fr-info-text">
                  <span class="fr-info-label">{item.label}</span>
                  <span class="fr-info-value">{item.value}</span>
                </div>
                <button
                  class="fr-copy-btn"
                  onclick={`navigator.clipboard.writeText('${item.value.replace(/'/g, "\\'")}');this.classList.add('copied');setTimeout(()=>this.classList.remove('copied'),1500)`}
                  aria-label={`复制${item.label}`}
                >
                  <Icon name="material-symbols:content-copy-outline-rounded" class="fr-copy-icon" />
                  <Icon name="material-symbols:check-rounded" class="fr-check-icon" />
                </button>
              </div>
            ))}
          </div>
        </section>
      )}

      <section class="fr-section">
        <div class="fr-section-head">
          <div class="fr-section-icon">
            <Icon name="material-symbols:list-alt-outline-rounded" />
          </div>
          <h3>申请流程</h3>
        </div>
        <div class="fr-steps">
          <div class="fr-step">
            <div class="fr-step-num">1</div>
            <div class="fr-step-line"></div>
            <div class="fr-step-content">
              <p class="fr-step-title">添加本站友链</p>
              {siteInfo ? (
                <p class="fr-step-desc">请先在您的网站友链页面添加本站信息，可直接复制上方各字段</p>
              ) : (
                <p class="fr-step-desc">请先在您的网站友链页面添加本站信息</p>
              )}
            </div>
          </div>
          <div class="fr-step">
            <div class="fr-step-num">2</div>
            <div class="fr-step-line"></div>
            <div class="fr-step-content">
              <p class="fr-step-title">通过 GitHub Issue 申请</p>
              <p class="fr-step-desc">点击下方按钮，在 GitHub 上提交 Issue 申请，自动填充模板</p>
              {issueUrl && (
                <div class="fr-issue-info">
                  <Icon name="fa7-brands:github" class="fr-issue-icon" />
                  <span class="fr-issue-text">基于 GitHub Issue 自动化处理</span>
                </div>
              )}
            </div>
          </div>
          <div class="fr-step">
            <div class="fr-step-num">3</div>
            <div class="fr-step-content">
              <p class="fr-step-title">等待审核</p>
              <p class="fr-step-desc">确认信息无误后会尽快添加您的友链，审核通过后自动合并</p>
            </div>
          </div>
        </div>
      </section>

      {notes && notes.length > 0 && (
        <section class="fr-section">
          <div class="fr-section-head">
            <div class="fr-section-icon">
              <Icon name="material-symbols:info-outline-rounded" />
            </div>
            <h3>注意事项</h3>
          </div>
          <div class="fr-notes">
            {notes.map((item: any) => (
              <div class="fr-note">
                <span class="fr-note-dot"></span>
                <p><strong>{item.title}</strong>：{item.content}</p>
              </div>
            ))}
          </div>
        </section>
      )}
    </div>

    <div class="fr-footer">
      {applyLink && issueUrl && (
        <a
          href={issueUrl}
          target="_blank"
          rel="noopener noreferrer"
          class="fr-btn fr-btn-primary"
        >
          <Icon name="fa7-brands:github" class="text-base" />
          通过 Issue 申请友链
        </a>
      )}
      <button class="fr-btn fr-btn-secondary" data-close-modal>
        <Icon name="material-symbols:check-rounded" class="text-base" />
        知道了
      </button>
    </div>
  </div>
</dialog>

<script>
  function initFriendRulesModal() {
    const modal = document.getElementById('friend-rules-modal') as HTMLDialogElement | null;
    if (!modal) return;

    const openBtns = document.querySelectorAll('[data-open-friend-rules]');
    openBtns.forEach(btn => {
      btn.addEventListener('click', (e) => {
        e.preventDefault();
        modal.showModal();
        document.body.style.overflow = 'hidden';
      });
    });

    modal.querySelectorAll('[data-close-modal]').forEach(el => {
      el.addEventListener('click', () => {
        modal.close();
        document.body.style.overflow = '';
      });
    });

    modal.addEventListener('click', (e) => {
      if (e.target === modal) {
        modal.close();
        document.body.style.overflow = '';
      }
    });

    modal.addEventListener('close', () => {
      document.body.style.overflow = '';
    });
  }

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', initFriendRulesModal);
  } else {
    initFriendRulesModal();
  }
  document.addEventListener('astro:page-load', initFriendRulesModal);
  document.addEventListener('astro:after-swap', initFriendRulesModal);
</script>

<style>
  .fr-modal {
    position: fixed;
    inset: 0;
    z-index: 99999;
    display: none;
    align-items: center;
    justify-content: center;
    padding: 1rem;
    border: none;
    background: transparent;
    width: 100%;
    height: 100%;
    max-width: 100%;
    max-height: 100%;
    overflow: visible;
  }
  .fr-modal[open] { display: flex; }
  .fr-modal::backdrop { background: transparent; }

  .fr-overlay {
    position: fixed;
    inset: 0;
    background: rgba(0, 0, 0, 0.5);
    backdrop-filter: blur(4px);
    z-index: -1;
    animation: frFadeIn 0.2s ease-out;
  }

  .fr-panel {
    background: #fff;
    border: 1px solid var(--line-divider);
    border-radius: 1rem;
    box-shadow: 0 25px 50px -12px rgba(0, 0, 0, 0.25);
    max-width: 40rem;
    width: 100%;
    max-height: 85vh;
    display: flex;
    flex-direction: column;
    animation: frSlideIn 0.3s cubic-bezier(0.16, 1, 0.3, 1);
  }
  :root.dark .fr-panel {
    background: #0f0f0f;
    border-color: var(--line-divider);
    box-shadow: 0 25px 50px -12px rgba(0, 0, 0, 0.6);
  }

  .fr-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 1.25rem 1.5rem;
    border-bottom: 1px solid var(--line-divider);
    flex-shrink: 0;
  }
  .fr-title {
    font-size: 1.25rem;
    font-weight: 700;
    color: #1a1a1a;
    margin: 0;
  }
  :root.dark .fr-title { color: #e5e5e5; }

  .fr-close {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 2.25rem;
    height: 2.25rem;
    border-radius: 0.5rem;
    border: none;
    background: transparent;
    color: #808080;
    cursor: pointer;
    transition: background 0.15s, color 0.15s;
  }
  .fr-close:hover {
    background: var(--btn-plain-bg-hover);
    color: #1a1a1a;
  }
  :root.dark .fr-close { color: #999; }
  :root.dark .fr-close:hover { color: #e5e5e5; }

  .fr-body {
    padding: 1.5rem;
    overflow-y: auto;
    flex: 1;
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
  }

  .fr-section-head {
    display: flex;
    align-items: center;
    gap: 0.625rem;
    margin-bottom: 0.875rem;
  }
  .fr-section-icon {
    width: 1.75rem;
    height: 1.75rem;
    border-radius: 0.5rem;
    background: #f2f2f2;
    color: #666;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 1rem;
    flex-shrink: 0;
  }
  :root.dark .fr-section-icon {
    background: #262626;
    color: #b3b3b3;
  }
  .fr-section-head h3 {
    font-size: 0.9375rem;
    font-weight: 600;
    color: #1a1a1a;
    margin: 0;
  }
  :root.dark .fr-section-head h3 { color: #d9d9d9; }

  .fr-info-grid {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }
  .fr-info-row {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 0.75rem;
    padding: 0.625rem 0.875rem;
    border-radius: 0.625rem;
    background: #f7f7f7;
    border: 1px solid #ebebeb;
  }
  :root.dark .fr-info-row {
    background: #1a1a1a;
    border-color: #333;
  }
  .fr-info-text { min-width: 0; flex: 1; }
  .fr-info-label {
    display: block;
    font-size: 0.6875rem;
    color: #8c8c8c;
    margin-bottom: 0.125rem;
  }
  :root.dark .fr-info-label { color: #808080; }
  .fr-info-value {
    display: block;
    font-size: 0.8125rem;
    font-weight: 500;
    color: #1a1a1a;
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
  }
  :root.dark .fr-info-value { color: #d9d9d9; }

  .fr-copy-btn {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 1.75rem;
    height: 1.75rem;
    border-radius: 0.375rem;
    border: none;
    background: #ebebeb;
    color: #666;
    cursor: pointer;
    transition: background 0.15s, color 0.15s;
    flex-shrink: 0;
    position: relative;
  }
  .fr-copy-btn:hover {
    background: #e0e0e0;
    color: #1a1a1a;
  }
  :root.dark .fr-copy-btn {
    background: #333;
    color: #999;
  }
  :root.dark .fr-copy-btn:hover {
    background: #404040;
    color: #d9d9d9;
  }
  .fr-copy-btn .fr-check-icon { display: none; }
  .fr-copy-btn.copied .fr-copy-icon { display: none; }
  .fr-copy-btn.copied .fr-check-icon { display: block; color: #52c41a; }

  .fr-steps { display: flex; flex-direction: column; }
  .fr-step {
    display: flex;
    gap: 0.875rem;
    position: relative;
  }
  .fr-step-num {
    width: 1.75rem;
    height: 1.75rem;
    border-radius: 50%;
    background: #4d4d4d;
    color: #fff;
    font-size: 0.75rem;
    font-weight: 700;
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
  }
  :root.dark .fr-step-num {
    background: #d9d9d9;
    color: #1a1a1a;
  }
  .fr-step-line {
    position: absolute;
    left: 0.875rem;
    top: 1.75rem;
    width: 1px;
    bottom: 0;
    background: var(--line-divider);
  }
  .fr-step-content {
    padding-bottom: 1rem;
    flex: 1;
    min-width: 0;
  }
  .fr-step:last-child .fr-step-content { padding-bottom: 0; }
  .fr-step-title {
    font-size: 0.875rem;
    font-weight: 600;
    color: #1a1a1a;
    margin: 0 0 0.25rem 0;
  }
  :root.dark .fr-step-title { color: #d9d9d9; }
  .fr-step-desc {
    font-size: 0.8125rem;
    color: #808080;
    margin: 0;
    line-height: 1.5;
  }
  :root.dark .fr-step-desc { color: #8c8c8c; }

  .fr-code {
    padding: 0.125rem 0.375rem;
    border-radius: 0.25rem;
    background: #f2f2f2;
    font-size: 0.75rem;
    font-family: monospace;
    border: 1px solid #e6e6e6;
  }
  :root.dark .fr-code {
    background: #262626;
    border-color: #333;
  }

  .fr-template {
    position: relative;
    margin-top: 0.625rem;
    border-radius: 0.5rem;
    background: #f7f7f7;
    border: 1px solid #ebebeb;
    padding: 0.875rem 2.5rem 0.875rem 0.875rem;
  }
  :root.dark .fr-template {
    background: #1a1a1a;
    border-color: #333;
  }
  .fr-template-copy {
    position: absolute;
    top: 0.5rem;
    right: 0.5rem;
  }
  .fr-template-text {
    font-size: 0.75rem;
    line-height: 1.6;
    color: #666;
    margin: 0;
    white-space: pre-wrap;
    word-break: break-all;
    font-family: monospace;
  }
  :root.dark .fr-template-text { color: #999; }

  .fr-issue-info {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    margin-top: 0.625rem;
    padding: 0.5rem 0.875rem;
    border-radius: 0.5rem;
    background: #f7f7f7;
    border: 1px solid #ebebeb;
  }
  :root.dark .fr-issue-info {
    background: #1a1a1a;
    border-color: #333;
  }
  .fr-issue-icon {
    font-size: 1rem;
    color: #333;
  }
  :root.dark .fr-issue-icon {
    color: #e5e5e5;
  }
  .fr-issue-text {
    font-size: 0.75rem;
    font-weight: 500;
    color: #666;
  }
  :root.dark .fr-issue-text { color: #b3b3b3; }

  .fr-notes {
    display: flex;
    flex-direction: column;
    gap: 0.625rem;
  }
  .fr-note {
    display: flex;
    align-items: flex-start;
    gap: 0.625rem;
    font-size: 0.8125rem;
    line-height: 1.6;
    color: #737373;
  }
  :root.dark .fr-note { color: #8c8c8c; }
  .fr-note-dot {
    width: 0.375rem;
    height: 0.375rem;
    border-radius: 50%;
    background: #4d4d4d;
    flex-shrink: 0;
    margin-top: 0.5rem;
  }
  :root.dark .fr-note-dot { background: #b3b3b3; }
  .fr-note strong {
    color: #1a1a1a;
    font-weight: 600;
  }
  :root.dark .fr-note strong { color: #ccc; }

  .fr-footer {
    display: flex;
    gap: 0.75rem;
    padding: 1.25rem 1.5rem;
    border-top: 1px solid var(--line-divider);
    justify-content: flex-end;
    flex-shrink: 0;
  }

  .fr-btn {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.625rem 1.25rem;
    border-radius: 0.625rem;
    font-size: 0.875rem;
    font-weight: 500;
    cursor: pointer;
    transition: opacity 0.15s, background 0.15s, color 0.15s;
    text-decoration: none;
    border: none;
    line-height: 1;
  }
  .fr-btn-primary {
    background: #4d4d4d;
    color: #fff;
  }
  .fr-btn-primary:hover { opacity: 0.9; }
  :root.dark .fr-btn-primary {
    background: #d9d9d9;
    color: #1a1a1a;
  }

  .fr-btn-secondary {
    background: transparent;
    border: 1px solid var(--line-divider);
    color: #4d4d4d;
  }
  .fr-btn-secondary:hover {
    background: var(--btn-plain-bg-hover);
  }
  :root.dark .fr-btn-secondary { color: #ccc; }

  @keyframes frFadeIn {
    from { opacity: 0; }
    to { opacity: 1; }
  }
  @keyframes frSlideIn {
    from { opacity: 0; transform: translateY(-0.75rem) scale(0.97); }
    to { opacity: 1; transform: translateY(0) scale(1); }
  }

  @media (max-width: 640px) {
    .fr-panel {
      max-width: calc(100% - 1.5rem);
      max-height: 90vh;
    }
    .fr-footer { flex-direction: column; }
    .fr-btn { justify-content: center; }
  }
</style>
