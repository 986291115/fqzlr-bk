---
import { Icon } from "astro-icon/components";
import { LinkPresets } from "@/constants/link-presets";
import { LinkPreset, type NavBarLink } from "@/types/config";
import { url } from "@/utils/url-utils";

interface Props {
	links: NavBarLink[];
}

const processedLinks = Astro.props.links.map((link: NavBarLink) => ({
	...link,
	children: link.children?.map((child: NavBarLink | LinkPreset): NavBarLink => {
		if (typeof child === "number") {
			return LinkPresets[child];
		}
		return child;
	}),
}));
---

<!-- 全屏遮罩层 -->
<div id="nav-menu-overlay" class="nav-fullscreen-overlay"></div>

<!-- 全屏菜单面板 -->
<div
	id="nav-menu-panel"
	class="nav-fullscreen-panel"
	data-menu-open="false"
	role="dialog"
	aria-modal="true"
	aria-label="导航菜单"
	aria-hidden="true"
>
	<!-- 关闭按钮 -->
	<button class="nav-fullscreen-close" aria-label="关闭菜单" id="nav-menu-close">
		<Icon name="material-symbols:close-rounded" class="text-[1.75rem]" />
	</button>

	<!-- 菜单内容 -->
	<div class="nav-fullscreen-content">
		{processedLinks.map((link, index) => (
			<div class="nav-fullscreen-item-wrapper" style={`--item-delay: ${index * 80}ms`}>
				{link.children && link.children.length > 0 ? (
					<!-- 有子菜单的项目 -->
					<div class="nav-fullscreen-dropdown" data-mobile-dropdown>
						<button
							class="nav-fullscreen-link nav-fullscreen-dropdown-trigger"
							data-mobile-dropdown-trigger
							aria-expanded="false"
						>
							<span class="nav-fullscreen-link-content">
								{link.icon && <Icon name={link.icon} class="text-[1.5rem]" />}
								<span>{link.name}</span>
							</span>
							<Icon
								name="material-symbols:keyboard-arrow-down-rounded"
								class="nav-fullscreen-arrow transition-transform duration-300"
							/>
						</button>
						<div class="nav-fullscreen-submenu" data-mobile-submenu>
							{link.children.map((child) => (
								<a
									href={child.external ? child.url : url(child.url)}
									class="nav-fullscreen-sublink"
									target={child.external ? "_blank" : undefined}
								>
									<span class="nav-fullscreen-link-content">
										{child.icon && <Icon name={child.icon} class="text-[1.25rem]" />}
										<span>{child.name}</span>
									</span>
									{child.external && (
										<Icon
											name="fa7-solid:arrow-up-right-from-square"
											class="text-[0.75rem] opacity-50"
										/>
									)}
								</a>
							))}
						</div>
					</div>
				) : (
					<!-- 普通链接项目 -->
					<a
						href={link.external ? link.url : url(link.url)}
						class="nav-fullscreen-link"
						target={link.external ? "_blank" : undefined}
					>
						<span class="nav-fullscreen-link-content">
							{link.icon && <Icon name={link.icon} class="text-[1.5rem]" />}
							<span>{link.name}</span>
						</span>
						{link.external && (
							<Icon
								name="fa7-solid:arrow-up-right-from-square"
								class="text-[0.75rem] opacity-50"
							/>
						)}
					</a>
				)}
			</div>
		))}
	</div>

	<!-- 底部装饰 -->
	<div class="nav-fullscreen-footer">
		<div class="nav-fullscreen-footer-line"></div>
	</div>
</div>

<style>
	@reference "../../styles/main.css";

	/* ============================================
	 * 全屏遮罩层
	 * ============================================ */
	.nav-fullscreen-overlay {
		display: none;
		position: fixed;
		inset: 0;
		background: rgba(0, 0, 0, 0.5);
		backdrop-filter: blur(4px);
		-webkit-backdrop-filter: blur(4px);
		z-index: 998;
		opacity: 0;
		transition: opacity 0.35s ease;
		pointer-events: none;
	}

	.nav-fullscreen-overlay.active {
		display: block;
		opacity: 1;
		pointer-events: auto;
	}

	/* ============================================
	 * 全屏菜单面板
	 * ============================================ */
	.nav-fullscreen-panel {
		position: fixed !important;
		inset: 0 !important;
		width: 100vw !important;
		height: 100dvh !important;
		background: var(--card-bg);
		transform: scale(0.95);
		opacity: 0;
		transition:
			transform 0.4s cubic-bezier(0.4, 0, 0.2, 1),
			opacity 0.4s ease;
		z-index: 999 !important;
		display: flex !important;
		flex-direction: column;
		align-items: center;
		justify-content: center;
		overflow: hidden;
		pointer-events: none;
	}

	.nav-fullscreen-panel[data-menu-open="true"] {
		transform: scale(1);
		opacity: 1;
		pointer-events: auto;
	}

	/* 桌面端隐藏全屏菜单 */
	@media (min-width: 1024px) {
		.nav-fullscreen-overlay,
		.nav-fullscreen-panel {
			display: none !important;
		}
	}

	/* ============================================
	 * 关闭按钮
	 * ============================================ */
	.nav-fullscreen-close {
		position: absolute;
		top: 1.25rem;
		right: 1.25rem;
		display: flex;
		align-items: center;
		justify-content: center;
		width: 3rem;
		height: 3rem;
		border-radius: 50%;
		color: var(--text-secondary);
		background: var(--btn-regular-bg);
		transition:
			background-color 0.2s ease,
			color 0.2s ease,
			transform 0.2s ease;
		cursor: pointer;
	}

	.nav-fullscreen-close:hover {
		background: var(--btn-regular-bg-hover);
		color: var(--primary);
	}

	.nav-fullscreen-close:active {
		transform: scale(0.9);
	}

	/* ============================================
	 * 菜单内容
	 * ============================================ */
	.nav-fullscreen-content {
		display: flex;
		flex-direction: column;
		align-items: center;
		gap: 0.25rem;
		width: 100%;
		max-width: 320px;
		padding: 0 1.5rem;
		overflow-y: auto;
		max-height: 70vh;
	}

	/* ============================================
	 * 菜单项动画
	 * ============================================ */
	.nav-fullscreen-item-wrapper {
		width: 100%;
		opacity: 0;
		transform: translateY(15px);
		transition:
			opacity 0.4s ease var(--item-delay),
			transform 0.4s cubic-bezier(0.4, 0, 0.2, 1) var(--item-delay) !important;
	}

	.nav-fullscreen-panel[data-menu-open="true"] .nav-fullscreen-item-wrapper {
		opacity: 1;
		transform: translateY(0);
	}

	/* ============================================
	 * 菜单链接
	 * ============================================ */
	.nav-fullscreen-link {
		display: flex;
		align-items: center;
		justify-content: center;
		gap: 0.75rem;
		padding: 1rem 1.5rem;
		border-radius: 1rem;
		color: var(--text-primary);
		transition:
			background-color 0.2s ease,
			color 0.2s ease,
			transform 0.15s ease;
		font-weight: 500;
		font-size: 1.125rem;
		text-align: center;
	}

	.nav-fullscreen-link:hover {
		background: var(--btn-plain-bg-hover);
		color: var(--primary);
		transform: scale(1.02);
	}

	.nav-fullscreen-link:active {
		background: var(--btn-plain-bg-active);
		transform: scale(0.98);
	}

	.nav-fullscreen-link-content {
		display: flex;
		align-items: center;
		gap: 0.75rem;
	}

	/* ============================================
	 * 子菜单
	 * ============================================ */
	.nav-fullscreen-dropdown {
		width: 100%;
		text-align: center;
	}

	.nav-fullscreen-dropdown-trigger {
		width: 100%;
		cursor: pointer;
	}

	.nav-fullscreen-dropdown-trigger .nav-fullscreen-arrow {
		color: var(--text-tertiary);
	}

	.nav-fullscreen-dropdown[data-expanded="true"] .nav-fullscreen-arrow {
		transform: rotate(180deg);
	}

	.nav-fullscreen-submenu {
		max-height: 0;
		overflow: hidden;
		transition: max-height 0.3s ease-in-out;
	}

	.nav-fullscreen-dropdown[data-expanded="true"] .nav-fullscreen-submenu {
		max-height: 500px;
	}

	.nav-fullscreen-sublink {
		display: flex;
		align-items: center;
		justify-content: center;
		gap: 0.5rem;
		padding: 0.75rem 1.5rem;
		border-radius: 0.75rem;
		color: var(--text-secondary);
		transition:
			background-color 0.2s ease,
			color 0.2s ease,
			transform 0.15s ease;
		font-weight: 400;
		font-size: 1rem;
	}

	.nav-fullscreen-sublink:hover {
		background: var(--btn-plain-bg-hover);
		color: var(--primary);
		transform: scale(1.01);
	}

	.nav-fullscreen-sublink:active {
		background: var(--btn-plain-bg-active);
		transform: scale(0.98);
	}

	/* ============================================
	 * 底部装饰
	 * ============================================ */
	.nav-fullscreen-footer {
		position: absolute;
		bottom: 2rem;
		left: 50%;
		transform: translateX(-50%);
		opacity: 0;
		transition: opacity 0.5s ease 0.6s;
	}

	.nav-fullscreen-panel[data-menu-open="true"] .nav-fullscreen-footer {
		opacity: 1;
	}

	.nav-fullscreen-footer-line {
		width: 40px;
		height: 4px;
		background: var(--line-divider);
		border-radius: 2px;
	}

	/* ============================================
	 * 暗色模式适配
	 * ============================================ */
	:global(.dark) .nav-fullscreen-panel {
		background: var(--card-bg);
	}
</style>

<script>
	(function () {
		let clickHandler: ((e: MouseEvent) => void) | null = null;
		let keydownHandler: ((e: KeyboardEvent) => void) | null = null;

		function openMenu() {
			const panel = document.getElementById("nav-menu-panel");
			const overlay = document.getElementById("nav-menu-overlay");
			if (panel) {
				panel.setAttribute("data-menu-open", "true");
				panel.removeAttribute("aria-hidden");
				document.body.style.overflow = "hidden";
			}
			if (overlay) {
				overlay.classList.add("active");
			}
		}

		function closeMenu() {
			const panel = document.getElementById("nav-menu-panel");
			const overlay = document.getElementById("nav-menu-overlay");
			if (panel) {
				panel.setAttribute("data-menu-open", "false");
				const closeBtn = panel.querySelector("#nav-menu-close");
				const menuSwitch = document.getElementById("nav-menu-switch");
				if (document.activeElement && panel.contains(document.activeElement)) {
					menuSwitch ? menuSwitch.focus() : closeBtn ? closeBtn.blur() : null;
				}
				panel.setAttribute("aria-hidden", "true");
				document.body.style.overflow = "";
			}
			if (overlay) {
				overlay.classList.remove("active");
			}
		}

		function toggleMenu() {
			const panel = document.getElementById("nav-menu-panel");
			if (!panel) {
				return;
			}
			const isOpen = panel.getAttribute("data-menu-open") === "true";
			if (isOpen) {
				closeMenu();
			} else {
				openMenu();
			}
		}

		function handleDropdownClick(e: Event) {
			const target = e.target as Node | null;
			if (!target) return;
			const trigger = (target as Element).closest?.(
				"[data-mobile-dropdown-trigger]"
			);
			if (!trigger) return;

			e.preventDefault();
			const dropdown = (trigger as Element).closest?.("[data-mobile-dropdown]");
			if (!dropdown) return;

			const isExpanded =
				(dropdown as Element).getAttribute("data-expanded") === "true";

			document
				.querySelectorAll("[data-mobile-dropdown]")
				.forEach(function (other) {
					if (other !== dropdown) {
						(other as Element).setAttribute("data-expanded", "false");
						const otherTrigger = (other as Element).querySelector(
							"[data-mobile-dropdown-trigger]"
						);
						if (otherTrigger) {
							(otherTrigger as Element).setAttribute(
								"aria-expanded",
								"false"
							);
						}
					}
				});

			(dropdown as Element).setAttribute("data-expanded", (!isExpanded).toString());
			(trigger as Element).setAttribute("aria-expanded", (!isExpanded).toString());
		}

		function handleClick(e: MouseEvent) {
			const target = e.target as Node | null;
			if (!target) return;

			if ((target as Element).closest?.("#nav-menu-switch")) {
				e.preventDefault();
				e.stopPropagation();
				toggleMenu();
				return;
			}

			const targetEl = target as Element;
			if (
				targetEl.id === "nav-menu-overlay" ||
				targetEl.classList?.contains("nav-fullscreen-overlay")
			) {
				e.preventDefault();
				closeMenu();
				return;
			}

			if ((target as Element).closest?.("#nav-menu-close")) {
				e.preventDefault();
				closeMenu();
				return;
			}

			if ((target as Element).closest?.("[data-mobile-dropdown-trigger]")) {
				handleDropdownClick(e);
				return;
			}
		}

		function handleKeydown(e: KeyboardEvent) {
			if (e.key === "Escape") {
				const panel = document.getElementById("nav-menu-panel");
				if (panel && panel.getAttribute("data-menu-open") === "true") {
					closeMenu();
				}
			}
		}

		function init() {
			if (clickHandler) {
				document.removeEventListener("click", clickHandler);
			}
			if (keydownHandler) {
				document.removeEventListener("keydown", keydownHandler);
			}

			clickHandler = handleClick;
			keydownHandler = handleKeydown;

			document.addEventListener("click", clickHandler);
			document.addEventListener("keydown", keydownHandler);
		}

		function onPageTransition() {
			closeMenu();
			init();
		}

		document.addEventListener("astro:page-load", init);
		document.addEventListener("swup:contentReplaced", onPageTransition);
		document.addEventListener("swup:page:view", onPageTransition);

		if (document.readyState === "complete" || document.readyState === "interactive") {
			init();
		}

		window.openNavMenu = openMenu;
		window.closeNavMenu = closeMenu;
		window.toggleNavMenu = toggleMenu;
	})();
</script>
