---
import { Icon } from "astro-icon/components";
import { LinkPresets } from "@/constants/link-presets";
import { LinkPreset, type NavBarLink } from "@/types/config";
import { url } from "@/utils/url-utils";

interface Props {
	links: NavBarLink[];
}

// 处理links中的LinkPreset转换
const processedLinks = Astro.props.links.map((link: NavBarLink) => ({
	...link,
	children: link.children?.map((child: NavBarLink | LinkPreset): NavBarLink => {
		if (typeof child === "number") {
			return LinkPresets[child];
		}
		return child;
	}),
}));
---

<!-- 抽屉遮罩层 -->
<div id="nav-menu-overlay" class="nav-drawer-overlay" aria-hidden="true"></div>

<!-- 抽屉菜单面板 -->
<div id="nav-menu-panel" class="nav-drawer-panel" role="dialog" aria-modal="true" aria-label="导航菜单">
	<!-- 抽屉头部 -->
	<div class="nav-drawer-header">
		<span class="nav-drawer-title">菜单</span>
		<button 
			class="nav-drawer-close" 
			aria-label="关闭菜单"
			id="nav-menu-close"
		>
			<Icon name="material-symbols:close-rounded" class="text-[1.5rem]" />
		</button>
	</div>
	
	<!-- 菜单内容 -->
	<div class="nav-drawer-content">
		{processedLinks.map((link, index) => (
			<div class="nav-drawer-item-wrapper" style={`--item-delay: ${index * 60}ms`}>
				{link.children && link.children.length > 0 ? (
					<!-- 有子菜单的项目 -->
					<div class="nav-drawer-dropdown" data-mobile-dropdown>
						<button 
							class="nav-drawer-link nav-drawer-dropdown-trigger"
							data-mobile-dropdown-trigger
							aria-expanded="false"
						>
							<span class="nav-drawer-link-content">
								{link.icon && <Icon name={link.icon} class="text-[1.25rem]" />}
								<span>{link.name}</span>
							</span>
							<Icon 
								name="material-symbols:keyboard-arrow-down-rounded"
								class="nav-drawer-arrow transition-transform duration-300"
							/>
						</button>
						<div class="nav-drawer-submenu" data-mobile-submenu>
							{link.children.map((child) => (
								<a href={child.external ? child.url : url(child.url)} 
								   class="nav-drawer-sublink"
								   target={child.external ? "_blank" : null}
								>
									<span class="nav-drawer-link-content">
										{child.icon && <Icon name={child.icon} class="text-[1.1rem]" />}
										<span>{child.name}</span>
									</span>
									{child.external && (
										<Icon name="fa7-solid:arrow-up-right-from-square" class="text-[0.75rem] opacity-50" />
									)}
								</a>
							))}
						</div>
					</div>
				) : (
					<!-- 普通链接项目 -->
					<a 
						href={link.external ? link.url : url(link.url)} 
						class="nav-drawer-link"
						target={link.external ? "_blank" : null}
					>
						<span class="nav-drawer-link-content">
							{link.icon && <Icon name={link.icon} class="text-[1.25rem]" />}
							<span>{link.name}</span>
						</span>
						{link.external && (
							<Icon name="fa7-solid:arrow-up-right-from-square" class="text-[0.75rem] opacity-50" />
						)}
					</a>
				)}
			</div>
		))}
	</div>
</div>

<style>
	@reference "../../styles/main.css";

	/* ============================================
	 * 抽屉遮罩层 - 仅移动端显示
	 * ============================================ */
	.nav-drawer-overlay {
		position: fixed;
		inset: 0;
		background: rgba(0, 0, 0, 0.5);
		backdrop-filter: blur(4px);
		opacity: 0;
		visibility: hidden;
		transition: opacity 0.3s ease, visibility 0.3s ease;
		z-index: 998;
	}

	.nav-drawer-overlay.active {
		opacity: 1;
		visibility: visible;
	}

	/* ============================================
	 * 抽屉面板 - 仅移动端显示
	 * ============================================ */
	.nav-drawer-panel {
		position: fixed;
		top: 0;
		right: 0;
		bottom: 0;
		width: min(320px, 85vw);
		background: var(--card-bg);
		box-shadow: -4px 0 24px rgba(0, 0, 0, 0.15);
		transform: translateX(100%);
		transition: transform 0.35s cubic-bezier(0.4, 0, 0.2, 1);
		z-index: 999;
		display: flex;
		flex-direction: column;
		overflow: hidden;
	}

	.nav-drawer-panel.open {
		transform: translateX(0);
	}

	/* 桌面端隐藏抽屉 */
	@media (min-width: 1024px) {
		.nav-drawer-overlay,
		.nav-drawer-panel {
			display: none;
		}
	}

	/* ============================================
	 * 抽屉头部
	 * ============================================ */
	.nav-drawer-header {
		display: flex;
		align-items: center;
		justify-content: space-between;
		padding: 1rem 1.25rem;
		border-bottom: 1px solid var(--line-divider);
		flex-shrink: 0;
	}

	.nav-drawer-title {
		font-weight: 700;
		font-size: 1.125rem;
		color: var(--text-primary);
	}

	.nav-drawer-close {
		display: flex;
		align-items: center;
		justify-content: center;
		width: 2.5rem;
		height: 2.5rem;
		border-radius: 0.5rem;
		color: var(--text-secondary);
		transition: background-color 0.2s ease, color 0.2s ease, transform 0.2s ease;
		cursor: pointer;
	}

	.nav-drawer-close:hover {
		background: var(--btn-plain-bg-hover);
		color: var(--primary);
	}

	.nav-drawer-close:active {
		transform: scale(0.95);
	}

	/* ============================================
	 * 菜单内容
	 * ============================================ */
	.nav-drawer-content {
		flex: 1;
		overflow-y: auto;
		padding: 0.75rem 0.75rem 1.5rem;
	}

	/* ============================================
	 * 菜单项淡入动画
	 * ============================================ */
	.nav-drawer-item-wrapper {
		opacity: 0;
		transform: translateX(20px);
		transition: 
			opacity 0.4s ease var(--item-delay),
			transform 0.4s cubic-bezier(0.4, 0, 0.2, 1) var(--item-delay);
	}

	.nav-drawer-panel.open .nav-drawer-item-wrapper {
		opacity: 1;
		transform: translateX(0);
	}

	/* ============================================
	 * 菜单链接
	 * ============================================ */
	.nav-drawer-link {
		display: flex;
		align-items: center;
		justify-content: space-between;
		padding: 0.875rem 1rem;
		border-radius: 0.625rem;
		color: var(--text-primary);
		transition: background-color 0.2s ease, color 0.2s ease;
		font-weight: 500;
	}

	.nav-drawer-link:hover {
		background: var(--btn-plain-bg-hover);
		color: var(--primary);
	}

	.nav-drawer-link:active {
		background: var(--btn-plain-bg-active);
	}

	.nav-drawer-link-content {
		display: flex;
		align-items: center;
		gap: 0.75rem;
	}

	/* ============================================
	 * 子菜单
	 * ============================================ */
	.nav-drawer-dropdown {
		margin-bottom: 0.25rem;
	}

	.nav-drawer-dropdown-trigger {
		width: 100%;
		cursor: pointer;
	}

	.nav-drawer-dropdown-trigger .nav-drawer-arrow {
		color: var(--text-tertiary);
	}

	.nav-drawer-dropdown[data-expanded="true"] .nav-drawer-arrow {
		transform: rotate(180deg);
	}

	.nav-drawer-submenu {
		max-height: 0;
		overflow: hidden;
		transition: max-height 0.3s ease-in-out;
	}

	.nav-drawer-dropdown[data-expanded="true"] .nav-drawer-submenu {
		max-height: 500px;
	}

	.nav-drawer-sublink {
		display: flex;
		align-items: center;
		justify-content: space-between;
		padding: 0.75rem 1rem 0.75rem 2.5rem;
		border-radius: 0.5rem;
		color: var(--text-secondary);
		transition: background-color 0.2s ease, color 0.2s ease;
		font-weight: 400;
		font-size: 0.9375rem;
	}

	.nav-drawer-sublink:hover {
		background: var(--btn-plain-bg-hover);
		color: var(--primary);
	}

	.nav-drawer-sublink:active {
		background: var(--btn-plain-bg-active);
	}

	/* ============================================
	 * 暗色模式适配
	 * ============================================ */
	:global(.dark) .nav-drawer-panel {
		background: var(--card-bg);
	}

	:global(.dark) .nav-drawer-overlay {
		background: rgba(0, 0, 0, 0.6);
	}
</style>

<script>
	document.addEventListener('DOMContentLoaded', function() {
		const overlay = document.getElementById('nav-menu-overlay');
		const panel = document.getElementById('nav-menu-panel');
		const menuBtn = document.getElementById('nav-menu-switch');
		const closeBtn = document.getElementById('nav-menu-close');
		const mobileDropdowns = document.querySelectorAll('[data-mobile-dropdown]');

		function openDrawer() {
			overlay?.classList.add('active');
			panel?.classList.add('open');
			document.body.style.overflow = 'hidden';
			// 设置ARIA属性
			overlay?.setAttribute('aria-hidden', 'false');
			panel?.setAttribute('aria-hidden', 'false');
		}

		function closeDrawer() {
			overlay?.classList.remove('active');
			panel?.classList.remove('open');
			document.body.style.overflow = '';
			// 设置ARIA属性
			overlay?.setAttribute('aria-hidden', 'true');
			panel?.setAttribute('aria-hidden', 'true');
		}

		// 菜单按钮点击
		menuBtn?.addEventListener('click', function() {
			if (panel?.classList.contains('open')) {
				closeDrawer();
			} else {
				openDrawer();
			}
		});

		// 关闭按钮点击
		closeBtn?.addEventListener('click', closeDrawer);

		// 遮罩层点击关闭
		overlay?.addEventListener('click', closeDrawer);

		// ESC键关闭
		document.addEventListener('keydown', function(e) {
			if (e.key === 'Escape' && panel?.classList.contains('open')) {
				closeDrawer();
			}
		});

		// 子菜单展开/折叠
		mobileDropdowns.forEach(dropdown => {
			const trigger = dropdown.querySelector('[data-mobile-dropdown-trigger]');
			
			if (!trigger) return;
			
			trigger.addEventListener('click', function(e) {
				e.preventDefault();
				const isExpanded = dropdown.getAttribute('data-expanded') === 'true';
				
				// 关闭其他打开的下拉菜单
				mobileDropdowns.forEach(otherDropdown => {
					if (otherDropdown !== dropdown) {
						otherDropdown.setAttribute('data-expanded', 'false');
						const otherTrigger = otherDropdown.querySelector('[data-mobile-dropdown-trigger]');
						if (otherTrigger) {
							otherTrigger.setAttribute('aria-expanded', 'false');
						}
					}
				});
				
				// 切换当前下拉菜单
				const newState = !isExpanded;
				dropdown.setAttribute('data-expanded', newState.toString());
				trigger.setAttribute('aria-expanded', newState.toString());
			});
		});

		// 处理页面切换 - 重置菜单状态
		document.addEventListener('swup:content:replace', function() {
			closeDrawer();
		});
	});
</script>
