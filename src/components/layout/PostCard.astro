---
import { render } from "astro:content";
import type { CollectionEntry } from "astro:content";
import { Icon } from "astro-icon/components";
import CoverImage from "@/components/common/CoverImage.astro";
import { siteConfig } from "@/config";
import I18nKey from "@/i18n/i18nKey";
import { i18n } from "@/i18n/translation";
import { getApiUrlList, processCoverImageSync } from "@/utils/image-utils";
import { getCategoryUrl, getFileDirFromPath, getTagUrl, url } from "@/utils/url-utils";

interface Props {
	class?: string;
	entry: CollectionEntry<"posts">;
	title: string;
	url: string;
	published: Date;
	updated?: Date;
	tags: string[];
	category: string | null;
	image: string;
	description: string;
	draft: boolean;
	pinned?: boolean;
	password?: string;
	style: string;
	loading?: "lazy" | "eager";
	fetchpriority?: "high" | "low" | "auto";
	index?: number;
}

const {
	entry,
	title,
	url: postUrl,
	published,
	tags,
	category,
	image,
	description,
	pinned,
	password,
	style,
	loading = "lazy",
	fetchpriority = "auto",
	index = 0,
} = Astro.props;

const className = Astro.props.class;

const processedImage = processCoverImageSync(image || "api", entry.id);
const apiUrls = getApiUrlList(image || "api", entry.id);
const hasCover = processedImage !== undefined && processedImage !== null && processedImage !== "";

const { remarkPluginFrontmatter } = await render(entry);
const descriptionText =
	description || remarkPluginFrontmatter.excerpt || "暂无文章简介，点击卡片查看完整内容。";

const dateFormatter = new Intl.DateTimeFormat(siteConfig.lang.replace("_", "-"), {
	year: "numeric",
	month: "2-digit",
	day: "2-digit",
});
const publishedText = dateFormatter.format(published);
const publishedIso = published.toISOString();

const rawCategory = category?.trim() || "";
const categoryName = rawCategory || i18n(I18nKey.uncategorized);
const categoryUrl = getCategoryUrl(rawCategory || null);

const tagList = (tags || [])
	.map((tag) => tag.trim())
	.filter(Boolean)
	.map((tag) => ({
		name: tag,
		url: getTagUrl(tag),
	}));

const categoryColorPalette = [
	"#fbbf24",
	"#fb7185",
	"#34d399",
	"#60a5fa",
	"#a78bfa",
	"#f472b6",
	"#2dd4bf",
	"#fb923c",
	"#22d3ee",
	"#818cf8",
	"#e879f9",
	"#a3e635",
	"#f87171",
	"#a78bfa",
	"#06b6d4",
	"#f59e0b",
	"#f43f5e",
	"#10b981",
];

function getCategoryColor(name: string): string {
	let hash = 0;
	for (let i = 0; i < name.length; i++) {
		hash = name.charCodeAt(i) + ((hash << 5) - hash);
	}
	const index = Math.abs(hash) % categoryColorPalette.length;
	return `color: ${categoryColorPalette[index]}`;
}

const fileDir = getFileDirFromPath(entry.filePath || "");
---

<!-- 单卡片：根据父容器 .list-mode / .grid-mode 切换显示样式 -->
<div
	class:list={["post-card-wrapper", { "is-pinned": pinned }, className]}
	data-post-id={entry.id}
	style={style || ''}
>
	<!-- 列表模式：背景图右侧 + 内容左对齐 -->
	<div class="article-list-row-card">
		{hasCover && (
			<div class="article-list-row-card__bg-wrapper">
				<CoverImage
					src={processedImage}
					basePath={fileDir}
					alt={`文章配图：${title}`}
					class="article-list-row-card__bg-image"
					loading={loading}
					fetchpriority={fetchpriority}
					apiUrls={apiUrls}
				/>
				<div class="article-list-row-card__gradient-overlay"></div>
			</div>
		)}

		<a href={postUrl} class="article-list-row-card__content" aria-label={`查看文章：${title}`}>
			<div class="article-list-row-card__layer-1">
				{pinned && (
					<span class="article-list-row-card__pinned-badge" aria-label="置顶文章">
						<Icon name="material-symbols:push-pin-rounded" class="text-[0.9rem]" />
						<span>{i18n(I18nKey.pinned)}</span>
					</span>
				)}
				<h3 class="article-list-row-card__title">
					{title}
					{password && (
						<span class="article-list-row-card__lock" aria-label="加密文章">
							<Icon name="material-symbols:lock-outline" class="text-[0.9rem]" />
						</span>
					)}
				</h3>
			</div>

			<div class="article-list-row-card__layer-2">
				<span class="al-category" style={getCategoryColor(categoryName)}>
					#{categoryName}
				</span>
				<span class="article-list-row-card__meta-item">
					<Icon name="material-symbols:calendar-month-rounded" class="text-[0.9rem]" />
					<time datetime={publishedIso}>{publishedText}</time>
				</span>
				{tagList.length > 0 && (
					<>
						{tagList.slice(0, 3).map((tag, i) => (
							<>
								{i > 0 && <span class="al-meta-divider" aria-hidden="true">/</span>}
								<span class="al-tag">{tag.name}</span>
							</>
						))}
						{tagList.length > 3 && (
							<span class="al-tag-more" aria-hidden="true">+{tagList.length - 3}</span>
						)}
					</>
				)}
			</div>

			<div class="article-list-row-card__layer-3">
				<p class="article-list-row-card__description">
					{descriptionText}
				</p>
			</div>
		</a>
	</div>

	<!-- 网格模式：封面图顶部 + 内容底部 -->
	<a href={postUrl} class="article-grid-card" aria-label={`查看文章：${title}`}>
		{hasCover && (
			<div class="article-grid-card__image-wrapper">
				<CoverImage
					src={processedImage}
					basePath={fileDir}
					alt={`文章配图：${title}`}
					class="article-grid-card__image"
					loading={loading}
					fetchpriority={fetchpriority}
					apiUrls={apiUrls}
				/>
				<div class="article-grid-card__gradient-overlay"></div>
				{pinned && (
					<span class="article-grid-card__pinned-badge article-grid-card__pinned-badge--corner">
						<Icon name="material-symbols:push-pin-rounded" class="text-[0.9rem]" />
						<span>{i18n(I18nKey.pinned)}</span>
					</span>
				)}
			</div>
		)}

		<div class="article-grid-card__content">
			<div class="article-grid-card__layer-1">
				<h3 class="article-grid-card__title">
					{title}
					{password && (
						<span class="article-grid-card__lock" aria-label="加密文章">
							<Icon name="material-symbols:lock-outline" class="text-[0.9rem]" />
						</span>
					)}
				</h3>
			</div>

			<div class="article-grid-card__layer-2">
				<span class="article-grid-card__meta-item">
					<Icon name="material-symbols:calendar-month-rounded" class="text-[0.9rem]" />
					<time datetime={publishedIso}>{publishedText}</time>
				</span>
			</div>

			<div class="article-grid-card__layer-3">
				<span class="ag-category" style={getCategoryColor(categoryName)}>
					#{categoryName}
				</span>
				{tagList.length > 0 && (
					<>
						<span class="ag-meta-gap" aria-hidden="true"></span>
						{tagList.slice(0, 2).map((tag, i) => (
							<>
								{i > 0 && <span class="ag-meta-divider" aria-hidden="true">/</span>}
								<span class="ag-tag">{tag.name}</span>
							</>
						))}
						{tagList.length > 2 && (
							<span class="ag-tag-more" aria-hidden="true">+{tagList.length - 2}</span>
						)}
					</>
				)}
			</div>
		</div>
	</a>
</div>
