---
import type { CollectionEntry } from "astro:content";
import { getPostUrlBySlug } from "@utils/url-utils";
import PostCard from "@/components/layout/PostCard.astro";
import { siteConfig } from "@/config";

const { page } = Astro.props;

let delay = 0;
const interval = 50;

type PostEntry = CollectionEntry<"posts">;

const defaultLayout = siteConfig.postListLayout?.defaultMode || "list";
const allowLayoutSwitch = siteConfig.postListLayout?.allowSwitch ?? true;
---

<div
	id="post-list-container"
	class:list={["post-list-root", "list-mode"]}
	data-default-layout={defaultLayout}
	data-allow-switch={String(allowLayoutSwitch)}
>
	{
		page.data.map((entry: PostEntry, index: number) => (
			<div
				class:list="onload-animation post-card-item"
				style={`animation-delay: calc(var(--content-delay) + ${delay++ * interval}ms);`}
			>
				<PostCard
					entry={entry}
					title={entry.data.title}
					tags={entry.data.tags}
					category={entry.data.category}
					published={entry.data.published}
					updated={entry.data.updated}
					url={getPostUrlBySlug(entry.id)}
					image={entry.data.image}
					description={entry.data.description}
					draft={entry.data.draft}
					pinned={entry.data.pinned}
					loading={index < 2 ? "eager" : "lazy"}
					index={index}
				/>
			</div>
		))
	}
</div>

<script is:inline>
	(function() {
		function applyLayoutMode(mode) {
			var container = document.getElementById("post-list-container");
			if (!container) return;
			container.classList.remove("list-mode", "grid-mode");
			container.classList.add(mode === "grid" ? "grid-mode" : "list-mode");
		}

		function initLayout() {
			var container = document.getElementById("post-list-container");
			if (!container) return;
			var defaultLayout = container.getAttribute("data-default-layout") || "list";
			var stored = localStorage.getItem("postListLayout");
			var mode = stored || defaultLayout;
			applyLayoutMode(mode);
		}

		function handleLayoutChange(e) {
			var mode = e.detail?.layout;
			if (mode === "grid" || mode === "list") {
				applyLayoutMode(mode);
			}
		}

		initLayout();
		window.addEventListener("layoutChange", handleLayoutChange);
		document.addEventListener("astro:page-load", initLayout);
	})();
</script>
